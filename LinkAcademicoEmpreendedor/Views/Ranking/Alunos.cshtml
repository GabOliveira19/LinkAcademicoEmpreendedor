@model List<LinkAcademicoEmpreendedor.ViewModels.RankingAlunoViewModel>
@{
    ViewData["Title"] = "Ranking de Alunos";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-trophy text-warning"></i> Ranking de Alunos</h2>
            <p class="text-muted mb-0">Os alunos mais ativos da plataforma</p>
        </div>
        <a asp-action="Empresas" class="btn btn-outline-success">
            <i class="bi bi-building"></i> Ranking de Empresas
        </a>
    </div>

    <!-- Legenda de Pontuacao -->
    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle"></i> <strong>Como funciona a pontuação:</strong>
        Projetos = 10 pts | Comentários = 3 pts | Curtidas = 1 pt
    </div>

    <!-- Top 3 -->
    @if (Model.Count >= 3)
    {
        <div class="row mb-4">
            <!-- 2o Lugar -->
            <div class="col-md-4 order-md-1 order-2">
                <div class="card text-center h-100 border-secondary">
                    <div class="card-body">
                        <div class="badge bg-secondary fs-5 mb-2">2°</div>
                        @if (!string.IsNullOrEmpty(Model[1].FotoPerfil))
                        {
                            <img src="@Model[1].FotoPerfil" class="rounded-circle mb-2" width="80" height="80" style="object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 80px; height: 80px;">
                                <i class="bi bi-person text-white fs-2"></i>
                            </div>
                        }
                        <h5>@Model[1].Nome</h5>
                        <p class="text-muted small mb-2">@Model[1].Curso</p>
                        <h4 class="text-secondary">@Model[1].PontuacaoTotal pts</h4>
                    </div>
                </div>
            </div>
            <!-- 1o Lugar -->
            <div class="col-md-4 order-md-2 order-1 mb-3 mb-md-0">
                <div class="card text-center h-100 border-warning bg-warning bg-opacity-10">
                    <div class="card-body">
                        <div class="badge bg-warning text-dark fs-4 mb-2"><i class="bi bi-trophy"></i> 1°</div>
                        @if (!string.IsNullOrEmpty(Model[0].FotoPerfil))
                        {
                            <img src="@Model[0].FotoPerfil" class="rounded-circle mb-2 border border-warning border-3" width="100" height="100" style="object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 100px; height: 100px;">
                                <i class="bi bi-person text-dark fs-1"></i>
                            </div>
                        }
                        <h4>@Model[0].Nome</h4>
                        <p class="text-muted mb-2">@Model[0].Curso</p>
                        <h3 class="text-warning">@Model[0].PontuacaoTotal pts</h3>
                    </div>
                </div>
            </div>
            <!-- 3o Lugar -->
            <div class="col-md-4 order-md-3 order-3">
                <div class="card text-center h-100" style="border-color: #cd7f32;">
                    <div class="card-body">
                        <div class="badge fs-5 mb-2" style="background-color: #cd7f32;">3°</div>
                        @if (!string.IsNullOrEmpty(Model[2].FotoPerfil))
                        {
                            <img src="@Model[2].FotoPerfil" class="rounded-circle mb-2" width="80" height="80" style="object-fit: cover;">
                        }
                        else
                        {
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 80px; height: 80px; background-color: #cd7f32;">
                                <i class="bi bi-person text-white fs-2"></i>
                            </div>
                        }
                        <h5>@Model[2].Nome</h5>
                        <p class="text-muted small mb-2">@Model[2].Curso</p>
                        <h4 style="color: #cd7f32;">@Model[2].PontuacaoTotal pts</h4>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Tabela Completa -->
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ol"></i> Ranking Completo</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 60px;">#</th>
                            <th>Aluno</th>
                            <th class="text-center">Projetos</th>
                            <th class="text-center">Comentários</th>
                            <th class="text-center">Curtidas</th>
                            <th class="text-center">Pontuação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var aluno in Model)
                        {
                            var rowClass = aluno.Posicao == 1 ? "table-warning" :
                            aluno.Posicao == 2 ? "table-secondary" :
                            aluno.Posicao == 3 ? "" : "";
                            <tr class="@rowClass">
                                <td class="text-center align-middle">
                                    @if (aluno.Posicao == 1)
                                    {
                                        <span class="badge bg-warning text-dark fs-6"><i class="bi bi-trophy"></i></span>
                                    }
                                    else if (aluno.Posicao == 2)
                                    {
                                        <span class="badge bg-secondary fs-6">2°</span>
                                    }
                                    else if (aluno.Posicao == 3)
                                    {
                                        <span class="badge fs-6" style="background-color: #cd7f32;">3°</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@aluno.Posicao</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(aluno.FotoPerfil))
                                        {
                                            <img src="@aluno.FotoPerfil" class="rounded-circle me-2" width="40" height="40" style="object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                                <i class="bi bi-person text-white"></i>
                                            </div>
                                        }
                                        <div>
                                            <strong>@aluno.Nome</strong>
                                            <br><small class="text-muted">@aluno.Curso - @aluno.Instituicao</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge bg-primary">@aluno.TotalProjetos</span>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge bg-info">@aluno.TotalComentarios</span>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge bg-danger">@aluno.TotalCurtidas</span>
                                </td>
                                <td class="text-center align-middle">
                                    <strong class="text-success fs-5">@aluno.PontuacaoTotal</strong>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>