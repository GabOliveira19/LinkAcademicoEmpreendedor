@model LinkAcademicoEmpreendedor.ViewModels.DashboardEmpresaViewModel
@{
    ViewData["Title"] = "Dashboard da Empresa";
}

<div class="container py-4">
    <div class="dashboard-topo-largo mx-auto">
        <div class="card shadow mb-4 bg-success text-white">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        @if (!string.IsNullOrEmpty(Model.Empresa?.LogoEmpresa))
                        {
                            <img src="@Model.Empresa.LogoEmpresa" class="rounded"
                                 style="width: 80px; height: 80px; object-fit: contain; background: white;" />
                        }
                        else
                        {
                            <div class="bg-white text-success rounded d-flex align-items-center justify-content-center"
                                 style="width: 80px; height: 80px; font-size: 2rem;">
                                <i class="bi bi-building"></i>
                            </div>
                        }
                    </div>

                    <div class="col">
                        <h3 class="mb-1">@Model.Empresa?.RazaoSocial</h3>
                        <p class="mb-0">@Model.Empresa?.AreaAtuacao</p>
                    </div>

                    <div class="col-auto">
                        <a asp-action="EditarPerfil" class="btn btn-light">
                            <i class="bi bi-pencil"></i> Editar perfil
                        </a>

                        <a asp-controller="Premium" asp-action="Planos" class="btn btn-warning ms-2">
                            <i class="bi bi-gem"></i> Seja Premium
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.AssinaturaPremium != null)
        {
            <div class="card shadow-sm border-warning mb-4">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <span class="badge bg-warning text-dark mb-2">
                            <i class="bi bi-gem"></i> Premium ativo
                        </span>

                        <h5 class="mb-1">
                            Plano Premium: @Model.AssinaturaPremium.PlanoPremium?.Nome
                        </h5>

                        <p class="mb-1 text-muted">
                            @Model.AssinaturaPremium.PlanoPremium?.Beneficios
                        </p>

                        <small class="text-muted">
                            Válido até @Model.AssinaturaPremium.Fim.ToString("dd/MM/yyyy")
                        </small>
                    </div>

                    <a asp-controller="Premium" asp-action="Planos" class="btn btn-outline-warning">
                        <i class="bi bi-arrow-up-circle"></i> Subir/Renovar plano
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card border-success h-100">
                <div class="card-body text-center">
                    <h2 class="text-success">@Model.MinhasOportunidades.Count</h2>
                    <p class="mb-0">Vagas publicadas</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-primary h-100">
                <div class="card-body text-center">
                    <h2 class="text-primary">@Model.MinhasOportunidades.Sum(o => o.Candidaturas?.Count ?? 0)</h2>
                    <p class="mb-0">Total de candidaturas</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-warning h-100">
                <div class="card-body text-center">
                    <h2 class="text-warning">@Model.ProjetosDestaque.Count</h2>
                    <p class="mb-0">Projetos em destaque</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-briefcase"></i> Minhas oportunidades</h5>
                    <a asp-controller="Oportunidade" asp-action="Criar" class="btn btn-sm btn-success">
                        <i class="bi bi-plus"></i> Nova vaga
                    </a>
                </div>

                <div class="card-body">
                    @if (Model.MinhasOportunidades.Any())
                    {
                        @foreach (var op in Model.MinhasOportunidades.Take(5))
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-0">@op.Titulo</h6>
                                        <small class="text-muted">@op.Tipo | @op.Modalidade</small>
                                    </div>

                                    <div class="btn-group">
                                        <a asp-controller="Candidatura" asp-action="Candidatos" asp-route-oportunidadeId="@op.Id"
                                           class="btn btn-sm btn-outline-primary" title="Ver candidatos">
                                            <i class="bi bi-people"></i> @(op.Candidaturas?.Count ?? 0)
                                        </a>

                                        <a asp-controller="Oportunidade" asp-action="Editar" asp-route-id="@op.Id"
                                           class="btn btn-sm btn-outline-secondary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-controller="Oportunidade" asp-action="Excluir" asp-route-id="@op.Id"
                                           class="btn btn-sm btn-outline-danger" title="Excluir">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-briefcase display-4 text-muted"></i>
                            <p class="text-muted mt-2">Nenhuma vaga publicada</p>
                            <a asp-controller="Oportunidade" asp-action="Criar" class="btn btn-success">Publicar vaga</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Talentos recentes</h5>
                    <a asp-action="BuscarTalentos" class="btn btn-sm btn-primary">
                        <i class="bi bi-search"></i> Buscar
                    </a>
                </div>

                <div class="list-group list-group-flush">
                    @foreach (var aluno in Model.AlunosRecentes)
                    {
                        <a asp-controller="Aluno" asp-action="Perfil" asp-route-id="@aluno.Id" class="list-group-item list-group-item-action">
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(aluno.FotoPerfil))
                                {
                                    <img src="@aluno.FotoPerfil" class="rounded-circle me-3"
                                         style="width: 40px; height: 40px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                                         style="width: 40px; height: 40px;">
                                        @aluno.Nome?.Substring(0, 1).ToUpper()
                                    </div>
                                }

                                <div>
                                    <strong>@aluno.Nome</strong>
                                    <br />
                                    <small class="text-muted">@aluno.Curso | @aluno.Projetos.Count projetos</small>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-star"></i> Projetos em destaque</h5>
        </div>

        <div class="card-body">
            <div class="row">
                @foreach (var projeto in Model.ProjetosDestaque)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <span class="badge bg-secondary mb-2">@projeto.Tipo</span>
                                <h6>@projeto.Titulo</h6>
                                <small class="text-muted">Por @projeto.Aluno?.Nome</small>

                                <div class="mt-2">
                                    <span class="text-danger">
                                        <i class="bi bi-heart-fill"></i> @projeto.TotalCurtidas
                                    </span>
                                </div>
                            </div>

                            <div class="card-footer bg-white">
                                <a asp-controller="Projeto" asp-action="Detalhes" asp-route-id="@projeto.Id"
                                   class="btn btn-sm btn-outline-primary w-100">Ver projeto</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="card shadow h-100 border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-trophy"></i> Ranking</h5>
                </div>

                <div class="card-body text-center">
                    <i class="bi bi-trophy text-warning" style="font-size: 3rem;"></i>
                    <p class="mt-3">Veja sua posição no ranking de empresas!</p>

                    <a asp-controller="Ranking" asp-action="Empresas" class="btn btn-warning">
                        <i class="bi bi-building"></i> Ver ranking de empresas
                    </a>

                    <a asp-controller="Ranking" asp-action="Alunos" class="btn btn-outline-primary mt-2">
                        <i class="bi bi-mortarboard"></i> Ver ranking de alunos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card shadow h-100 border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-star-fill"></i> Minhas Avaliações</h5>
                </div>

                <div class="card-body text-center">
                    <i class="bi bi-star-fill text-warning" style="font-size: 3rem;"></i>
                    <p class="mt-3">Veja as avaliacoes que voce recebeu dos alunos.</p>

                    <a asp-controller="Avaliacao" asp-action="MinhasAvaliacoes" class="btn btn-success">
                        <i class="bi bi-star"></i> Avaliações Recebidas
                    </a>

                    <a asp-controller="Avaliacao" asp-action="AvaliacoesFeitas" class="btn btn-outline-success mt-2">
                        <i class="bi bi-send"></i> Avaliações que Fiz
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-star-fill"></i> Avaliações</h5>
                </div>

                <div class="card-body">
                    <p>Avalie os alunos que se candidataram e veja suas avaliações recebidas.</p>

                    <div class="d-grid gap-2">
                        <a asp-controller="Avaliacao" asp-action="MinhasAvaliacoes" class="btn btn-warning">
                            <i class="bi bi-star"></i> Minhas Avaliações Recebidas
                        </a>

                        <a asp-controller="Avaliacao" asp-action="AvaliacoesFeitas" class="btn btn-outline-warning">
                            <i class="bi bi-send"></i> Avaliações que Fiz
                        </a>

                        <a asp-controller="Oportunidade" asp-action="MinhasOportunidades" class="btn btn-outline-success">
                            <i class="bi bi-people"></i> Ver Candidatos (Avaliar Alunos)
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dashboard-topo-largo {
        width: min(100%, 1620px);
    }

    @@media (max-width: 768px) {
        .dashboard-topo-largo {
            width: 100%;
        }

            .dashboard-topo-largo .col-auto {
                width: 100%;
                margin-top: 1rem;
            }

            .dashboard-topo-largo .btn {
                width: 100%;
                margin-left: 0 !important;
                margin-top: 0.5rem;
            }
    }
</style>