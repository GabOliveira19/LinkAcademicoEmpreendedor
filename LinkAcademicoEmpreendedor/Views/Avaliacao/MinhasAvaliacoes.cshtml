@model List<LinkAcademicoEmpreendedor.Models.Avaliacao>
@{
    ViewData["Title"] = "Minhas Avaliacoes";
    var tipoUsuario = ViewBag.TipoUsuario as string;
    var total = ViewBag.TotalAvaliacoes;
    var media = ViewBag.MediaAvaliacoes;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-star-fill text-warning"></i> Minhas Avaliacoes Recebidas</h2>
            <p class="text-muted mb-0">Veja o que estao falando sobre voce</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="AvaliacoesFeitas" class="btn btn-outline-primary">
                <i class="bi bi-send"></i> Avaliacoes Feitas
            </a>
            @if (tipoUsuario == "Aluno")
            {
                <a asp-controller="Aluno" asp-action="Dashboard" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Dashboard
                </a>
            }
            else
            {
                <a asp-controller="Empresa" asp-action="Dashboard" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Dashboard
                </a>
            }
        </div>
    </div>

    <!-- Estatisticas -->
    <div class="row mb-4">
        <div class="col-md-4 col-6 mb-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body text-center">
                    <i class="bi bi-star-fill fs-2"></i>
                    <h2 class="mb-0 mt-2">
                        @if (media != null && (double)media > 0)
                        {
                            @(((double)media).ToString("0.1"))
                        }
                        else
                        {
                            @:--
                        }
                    </h2>
                    <small>Media Geral</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-6 mb-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-chat-dots fs-2"></i>
                    <h2 class="mb-0 mt-2">@total</h2>
                    <small>Total Avaliacoes</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-6 mb-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-trophy fs-2"></i>
                    <h2 class="mb-0 mt-2">@Model.Count(a => a.Nota == 5)</h2>
                    <small>5 Estrelas</small>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-star fs-1 text-muted d-block mb-3"></i>
                <h5>Nenhuma avaliacao recebida ainda</h5>
                <p class="text-muted">Quando alguem avaliar voce, aparecera aqui.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var avaliacao in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="badge bg-@(avaliacao.TipoAvaliador == "Aluno" ? "primary" : "success")">
                                <i class="bi bi-@(avaliacao.TipoAvaliador == "Aluno" ? "mortarboard" : "building")"></i>
                                @avaliacao.TipoAvaliador
                            </span>
                            <small class="text-muted">@avaliacao.DataAvaliacao.ToString("dd/MM/yyyy")</small>
                        </div>
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                @if (!string.IsNullOrEmpty(avaliacao.FotoAvaliador))
                                {
                                    <img src="@avaliacao.FotoAvaliador" class="rounded-circle me-3" width="50" height="50" style="object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                        <i class="bi bi-person text-white"></i>
                                    </div>
                                }
                                <div>
                                    <strong>@avaliacao.NomeAvaliador</strong>
                                </div>
                            </div>

                            <!-- Estrelas -->
                            <div class="text-center mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= avaliacao.Nota)
                                    {
                                        <i class="bi bi-star-fill text-warning fs-4"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-warning fs-4"></i>
                                    }
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(avaliacao.Comentario))
                            {
                                <div class="bg-light rounded p-3">
                                    <i class="bi bi-chat-quote text-muted"></i>
                                    <p class="mb-0 small fst-italic">"@avaliacao.Comentario"</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>