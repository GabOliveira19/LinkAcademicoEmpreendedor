@{
    ViewData["Title"] = "Assistente IA";
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0 rounded-4">

                <!-- Cabeçalho -->
                <div class="card-header bg-success text-white rounded-top-4">
                    <h4 class="mb-0 fw-bold">
                        🤖 SkillBot
                    </h4>
                </div>

                <div class="card-body">

                    <!-- Caixa do chat -->
                    <div id="chatBox"
                         style="
                            height: 450px;
                            overflow-y: auto;
                            border: 1px solid #dee2e6;
                            border-radius: 15px;
                            padding: 20px;
                            background-color: #f8f9fa;
                         ">

                        <!-- Mensagem inicial -->
                        <div class="mb-3">
                            <strong>SkillBot:</strong>
                            Bem-vindo ao SkillBridge! Sou o assistente virtual da plataforma. Como posso ajudar você hoje?
                        </div>

                    </div>

                    <!-- Campo mensagem -->
                    <div class="mt-3">

                        <div class="d-flex align-items-center">

                            <!-- Botão raio -->
                            <div class="dropdown me-2">

                                <button class="btn btn-outline-warning rounded-circle fw-bold shadow-sm"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        title="Sugestões rápidas"
                                        style="
                                            width: 52px;
                                            height: 48px;
                                            font-size: 22px;
                                        ">
                                    ⚡
                                </button>

                                <!-- Sugestões -->
                                <ul class="dropdown-menu shadow border-0 rounded-4 p-2"
                                    style="min-width: 280px;">

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Criar Projeto')">
                                            📁 Criar Projeto
                                        </button>
                                    </li>

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Ver ranking de alunos')">
                                            🏆 Ver ranking de alunos
                                        </button>
                                    </li>

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Ver ranking de empresas')">
                                            🏢 Ver ranking de empresas
                                        </button>
                                    </li>

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Como editar meu perfil?')">
                                            👤 Como editar meu perfil?
                                        </button>
                                    </li>

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Quero ver vagas')">
                                            💼 Quero ver vagas
                                        </button>
                                    </li>

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Ver currículos de alunos')">
                                            📄 Ver currículos de alunos
                                        </button>
                                    </li>

                                    <li>
                                        <button class="dropdown-item rounded-3"
                                                onclick="usarSugestao('Ajuda')">
                                            ❓ Ajuda
                                        </button>
                                    </li>

                                </ul>

                            </div>

                            <!-- Input -->
                            <input type="text"
                                   id="mensagem"
                                   class="form-control rounded-pill"
                                   placeholder="Digite sua pergunta..."
                                   onkeypress="if(event.key === 'Enter') enviarMensagem()" />

                            <!-- Botão enviar -->
                            <button class="btn btn-success ms-2 rounded-pill px-4"
                                    onclick="enviarMensagem()">
                                Enviar
                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .dropdown-item {
        transition: all 0.2s ease;
        padding: 10px 12px;
        font-size: 0.95rem;
    }

        .dropdown-item:hover {
            background-color: #f1f3f5;
            transform: translateX(3px);
        }

</style>

<script>

    // Usar sugestão
    function usarSugestao(texto) {

        document.getElementById('mensagem').value = texto;

        enviarMensagem();
    }

    async function enviarMensagem() {

        let mensagemInput = document.getElementById('mensagem');

        let mensagem = mensagemInput.value.trim();

        if (mensagem === '')
            return;

        let chatBox = document.getElementById('chatBox');

        // Mensagem usuário
        chatBox.innerHTML += `
            <div class="mb-3 text-end">
                <div style="
                    display: inline-block;
                    background-color: #198754;
                    color: white;
                    padding: 10px 15px;
                    border-radius: 15px;
                    max-width: 75%;
                    text-align: left;
                ">
                    <strong>Você:</strong><br>
                    ${mensagem}
                </div>
            </div>
        `;

        // Limpa input
        mensagemInput.value = '';

        // Scroll automático
        chatBox.scrollTop = chatBox.scrollHeight;

        try {

            // Envia para controller
            const response = await fetch('/ChatBot/EnviarMensagem', {

                method: 'POST',

                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },

                body: `mensagem=${encodeURIComponent(mensagem)}`
            });

            const data = await response.json();

            // Resposta IA
            chatBox.innerHTML += `
                <div class="mb-3">
                    <div style="
                        display: inline-block;
                        background-color: white;
                        border: 1px solid #dee2e6;
                        padding: 10px 15px;
                        border-radius: 15px;
                        max-width: 75%;
                    ">
                        <strong>SkillBot:</strong><br>
                        ${data.resposta}
                    </div>
                </div>
            `;

            // Scroll automático
            chatBox.scrollTop = chatBox.scrollHeight;

            // Redirecionamento
            if (data.redirecionar && data.redirecionar !== "") {

                setTimeout(() => {

                    window.location.href = data.redirecionar;

                }, 2000);
            }

        }
        catch (erro) {

            chatBox.innerHTML += `
                <div class="mb-3">
                    <div style="
                        display: inline-block;
                        background-color: #f8d7da;
                        color: #842029;
                        border: 1px solid #f5c2c7;
                        padding: 10px 15px;
                        border-radius: 15px;
                    ">
                        <strong>Erro:</strong><br>
                        Não foi possível conectar ao assistente virtual.
                    </div>
                </div>
            `;
        }
    }

</script>