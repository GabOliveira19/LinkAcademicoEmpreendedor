@{
    ViewData["Title"] = "Assistente IA";
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-success text-white rounded-top-4">
                    <h4 class="mb-0 fw-bold">
                        🤖 SkillBot
                    </h4>
                </div>

                <div class="card-body">

                    <!-- Caixa do chat -->
                    <div id="chatBox"
                         style="
                            height: 450px;
                            overflow-y: auto;
                            border: 1px solid #dee2e6;
                            border-radius: 15px;
                            padding: 20px;
                            background-color: #f8f9fa;
                         ">

                        <!-- Mensagem inicial -->
                        <div class="mb-3">
                            <strong>SkillBot:</strong>
                            Bem-vindo ao SkillBridge! Sou o assistente virtual da plataforma. Como posso ajudar você hoje?
                        </div>

                    </div>

                    <!-- Campo mensagem -->
                    <div class="mt-3 d-flex">

                        <input type="text"
                               id="mensagem"
                               class="form-control rounded-pill"
                               placeholder="Digite sua pergunta..."
                               onkeypress="if(event.key === 'Enter') enviarMensagem()" />

                        <button class="btn btn-success ms-2 rounded-pill px-4"
                                onclick="enviarMensagem()">
                            Enviar
                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

    async function enviarMensagem() {

        let mensagemInput = document.getElementById('mensagem');

        let mensagem = mensagemInput.value.trim();

        if (mensagem === '')
            return;

        let chatBox = document.getElementById('chatBox');

        // Mostra mensagem do usuário
        chatBox.innerHTML += `
            <div class="mb-3 text-end">
                <div style="
                    display: inline-block;
                    background-color: #198754;
                    color: white;
                    padding: 10px 15px;
                    border-radius: 15px;
                    max-width: 75%;
                ">
                    <strong>Você:</strong><br>
                    ${mensagem}
                </div>
            </div>
        `;

        // Limpa input
        mensagemInput.value = '';

        // Scroll automático
        chatBox.scrollTop = chatBox.scrollHeight;

        try {

            // Envia para controller
            const response = await fetch('/ChatBot/EnviarMensagem', {

                method: 'POST',

                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },

                body: `mensagem=${encodeURIComponent(mensagem)}`
            });

            const data = await response.json();

            // Mostra resposta da IA
            chatBox.innerHTML += `
                <div class="mb-3">
                    <div style="
                        display: inline-block;
                        background-color: white;
                        border: 1px solid #dee2e6;
                        padding: 10px 15px;
                        border-radius: 15px;
                        max-width: 75%;
                    ">
                        <strong>SkillBot:</strong><br>
                        ${data.resposta}
                    </div>
                </div>
            `;

            // Scroll automático
            chatBox.scrollTop = chatBox.scrollHeight;

            // REDIRECIONAMENTO AUTOMÁTICO
            if (data.redirecionar && data.redirecionar !== "") {

                setTimeout(() => {

                    window.location.href = data.redirecionar;

                }, 2000);
            }

        }
        catch (erro) {

            chatBox.innerHTML += `
                <div class="mb-3">
                    <div style="
                        display: inline-block;
                        background-color: #f8d7da;
                        color: #842029;
                        border: 1px solid #f5c2c7;
                        padding: 10px 15px;
                        border-radius: 15px;
                    ">
                        <strong>Erro:</strong><br>
                        Não foi possível conectar ao assistente virtual.
                    </div>
                </div>
            `;
        }
    }

</script>