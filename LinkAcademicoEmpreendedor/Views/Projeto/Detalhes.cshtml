@model LinkAcademicoEmpreendedor.Models.Projeto
@{
    ViewData["Title"] = Model.Titulo;
}

<div class="container py-4">
    <div class="row">

        <!-- CONTEÚDO PRINCIPAL -->
        <div class="col-lg-8">

            <div class="card shadow mb-4">
                <div class="card-body">

                    <!-- CABEÇALHO -->
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <span class="badge bg-secondary mb-2">@Model.Tipo</span>
                            <h2>@Model.Titulo</h2>
                        </div>

                        <div class="text-end">
                            <span class="h4 text-danger me-3">
                                <i class="bi bi-heart-fill"></i>
                                <span id="totalCurtidas">@Model.TotalCurtidas</span>
                            </span>

                            <span class="h4 text-primary">
                                <i class="bi bi-chat-fill"></i>
                                @Model.TotalComentarios
                            </span>
                        </div>
                    </div>

                    <!-- Descricao -->
                    <div class="mb-4">
                        @Html.Raw(Model.Descricao)
                    </div>

                    <!-- ÁREA -->
                    <span class="badge bg-success mb-3">@Model.Area</span>

                    <!-- PDF -->
                    @if (!string.IsNullOrEmpty(Model.ArquivoPdf))
                    {
                        <div class="mb-4">
                            <a href="@Model.ArquivoPdf"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="btn btn-outline-danger">
                                <i class="bi bi-file-earmark-pdf"></i>
                                Ver PDF do Projeto
                            </a>
                        </div>
                    }

                    <!-- DADOS DINÂMICOS -->
                    @if (Model.DadosDinamicos != null && Model.DadosDinamicos.Any())
                    {
                        <hr />

                        <h5 class="mb-3">
                            <i class="bi bi-info-circle"></i>
                            Informações Complementares
                        </h5>

                        <div class="row">
                            @foreach (var campo in Model.DadosDinamicos)
                            {
                                bool ehLink =
                                !string.IsNullOrWhiteSpace(campo.Value) &&
                                (
                                campo.Value.StartsWith("http://") ||
                                campo.Value.StartsWith("https://") ||
                                campo.Value.StartsWith("www.")
                                );

                                <div class="col-md-6 mb-3">
                                    <strong>@campo.Key</strong>
                                    <br />

                                    @if (ehLink)
                                    {
                                        <a href="@(campo.Value.StartsWith("www.") ? "https://" + campo.Value : campo.Value)"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           class="btn btn-sm btn-outline-primary mt-2">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                            Abrir Link
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@campo.Value</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (Model.Links != null && Model.Links.Any())
                    {
                        <hr />

                        <h5 class="mb-3">
                            <i class="bi bi-link-45deg"></i> Links Relacionados
                        </h5>

                        <div class="row">
                            @foreach (var link in Model.Links)
                            {
                                <div class="col-md-6 mb-3">
                                    <strong>@link.Tipo</strong>
                                    <br />

                                    <a href="@link.Url"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       class="btn btn-sm btn-outline-primary mt-1">
                                        <i class="bi bi-box-arrow-up-right"></i> Abrir Link
                                    </a>
                                </div>
                            }
                        </div>
                    }

                    <hr />

                    <!-- CURTIR -->
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            Publicado em @Model.DataCriacao.ToString("dd/MM/yyyy")
                        </small>

                        @if (ViewBag.UserId != null &&
                                                (ViewBag.TipoUsuario == "Aluno" || ViewBag.TipoUsuario == "Empresa"))
                        {
                            <form id="formCurtir" method="post">
                                @Html.AntiForgeryToken()

                                <button type="button"
                                        id="btnCurtir"
                                        class="btn @(ViewBag.JaCurtiu ? "btn-danger" : "btn-outline-danger")"
                                        onclick="curtirProjeto(@Model.Id)">

                                    <i class="bi @(ViewBag.JaCurtiu ? "bi-heart-fill" : "bi-heart")"></i>

                                    <span id="textoCurtir">
                                        @(ViewBag.JaCurtiu ? "Curtido" : "Curtir")
                                    </span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-outline-danger">
                                <i class="bi bi-heart"></i>
                                Faça login para curtir
                            </a>
                        }
                    </div>

                </div>
            </div>

            <!-- COMENTÁRIOS -->
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-chat-dots"></i>
                        Comentários (@Model.Comentarios.Count)
                    </h5>
                </div>

                <div class="card-body">

                    @if (ViewBag.UserId != null)
                    {
                        <form asp-action="Comentar" method="post" class="mb-4">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="projetoId" value="@Model.Id" />

                            <textarea name="texto"
                                  class="form-control mb-2"
                                  rows="3"
                                  placeholder="Escreva um comentário..."
                                  required></textarea>

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i>
                                Comentar
                            </button>
                        </form>
                    }

                    @foreach (var comentario in Model.Comentarios.OrderByDescending(c => c.DataComentario))
                    {
                        <div class="border rounded p-3 mb-2">
                            <div class="d-flex justify-content-between">
                                <strong>
                                    @(comentario.Aluno?.Nome ?? comentario.Empresa?.RazaoSocial)

                                    @if (comentario.EmpresaId != null)
                                    {
                                        <span class="badge bg-primary ms-2">Empresa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success ms-2">Aluno</span>
                                    }
                                </strong>

                                <small class="text-muted">
                                    @comentario.DataComentario.ToString("dd/MM/yyyy HH:mm")
                                </small>
                            </div>

                            <p class="mb-0 mt-2">@comentario.Texto</p>
                        </div>
                    }

                </div>
            </div>

        </div>

        <!-- SIDEBAR AUTOR -->
        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person"></i>
                        Autor
                    </h5>
                </div>

                <div class="card-body text-center">

                    @if (!string.IsNullOrEmpty(Model.Aluno?.FotoPerfil))
                    {
                        <img src="@Model.Aluno.FotoPerfil"
                             class="rounded-circle mb-3"
                             style="width:80px;height:80px;object-fit:cover;" />
                    }

                    <h5>@Model.Aluno?.Nome</h5>
                    <p class="text-muted">@Model.Aluno?.Curso</p>
                    <p class="text-muted">@Model.Aluno?.Instituicao</p>

                    <a asp-controller="Aluno"
                       asp-action="Perfil"
                       asp-route-id="@Model.AlunoId"
                       class="btn btn-outline-primary w-100">
                        Ver Perfil Completo
                    </a>

                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function curtirProjeto(projetoId) {
            const token =
                document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/Projeto/Curtir', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'id=' + projetoId +
                      '&__RequestVerificationToken=' +
                      encodeURIComponent(token)
            })
            .then(r => r.json())
            .then(data => {
                if (!data.success) {
                    alert(data.message);
                    return;
                }

                document.getElementById('totalCurtidas').textContent = data.total;

                const btn = document.getElementById('btnCurtir');
                const texto = document.getElementById('textoCurtir');
                const icon = btn.querySelector('i');

                if (data.curtiu) {
                    btn.classList.remove('btn-outline-danger');
                    btn.classList.add('btn-danger');

                    texto.textContent = 'Curtido';

                    icon.classList.remove('bi-heart');
                    icon.classList.add('bi-heart-fill');
                }
                else {
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-outline-danger');

                    texto.textContent = 'Curtir';

                    icon.classList.remove('bi-heart-fill');
                    icon.classList.add('bi-heart');
                }
            })
            .catch(() => {
                alert('Erro ao curtir projeto.');
            });
        }
    </script>
}