@model LinkAcademicoEmpreendedor.Models.Projeto
@{
    ViewData["Title"] = Model.Titulo;
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <!-- Projeto -->
            <div class="card shadow mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <span class="badge bg-secondary mb-2">@Model.Tipo</span>
                            <h2>@Model.Titulo</h2>
                        </div>
                        <div class="text-end">
                            <span class="h4 text-danger me-3">
                                <i class="bi bi-heart-fill"></i> <span id="totalCurtidas">@Model.TotalCurtidas</span>
                            </span>
                            <span class="h4 text-primary">
                                <i class="bi bi-chat-fill"></i> @Model.TotalComentarios
                            </span>
                        </div>
                    </div>

                    <div>
                        @Html.Raw(Model.Descricao)
                    </div>
                    @if (Model.Links != null && Model.Links.Any())
                    {
                        <h5 class="mt-4">Links do Projeto</h5>

                        <div class="row">
                            @foreach (var link in Model.Links)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card shadow-sm h-100">
                                        <div class="card-body">
                                            <h6 class="fw-bold">@link.Tipo</h6>

                                            <p class="text-muted small text-truncate">
                                                @link.Url
                                            </p>

                                            <a href="@link.Url" target="_blank" class="btn btn-sm btn-primary">
                                                🔗 Acessar
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                    }
                    @if (!string.IsNullOrEmpty(Model.Tecnologias))
                    {
                        <div class="mt-3">
                            <h6>Tecnologias:</h6>

                            @foreach (var tech in Model.Tecnologias.Split(","))
                            {
                                <span class="badge bg-primary me-1">@tech.Trim()</span>
                            }
                        </div>
                    }
                    <span class="badge bg-success">@Model.Area</span>

                    @if (!string.IsNullOrEmpty(Model.ArquivoPdf))
                    {
                        <a href="@Model.ArquivoPdf" target="_blank" class="btn btn-outline-danger mt-3">
                            📄 Ver PDF do Projeto
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(Model.Tecnologias))
                    {
                        <div class="mb-3">
                            <strong>Tecnologias:</strong>
                            @foreach (var tech in Model.Tecnologias.Split(','))
                            {
                                <span class="badge bg-primary me-1">@tech.Trim()</span>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.LinkRepositorio))
                        {
                            <a href="@Model.LinkRepositorio" target="_blank" class="btn btn-outline-dark me-2">
                                <i class="bi bi-github"></i> Repositorio
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.LinkDemonstracao))
                        {
                            <a href="@Model.LinkDemonstracao" target="_blank" class="btn btn-outline-primary">
                                <i class="bi bi-link-45deg"></i> Demonstracao
                            </a>
                        }
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Publicado em @Model.DataCriacao.ToString("dd/MM/yyyy")</small>
                        @if (ViewBag.UserId != null && (ViewBag.TipoUsuario == "Aluno" || ViewBag.TipoUsuario == "Empresa"))
                        {
                            <form id="formCurtir" method="post">
                                @Html.AntiForgeryToken()
                                <button type="button" id="btnCurtir"
                                        class="btn @(ViewBag.JaCurtiu ? "btn-danger" : "btn-outline-danger")"
                                        onclick="curtirProjeto(@Model.Id)">
                                    <i class="bi @(ViewBag.JaCurtiu ? "bi-heart-fill" : "bi-heart")"></i>
                                    <span id="textoCurtir">@(ViewBag.JaCurtiu ? "Curtido" : "Curtir")</span>
                                </button>
                            </form>
                        }
                        else if (ViewBag.UserId == null)
                        {
                            <a href="/Account/Login" class="btn btn-outline-danger">
                                <i class="bi bi-heart"></i> Faca login para curtir
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- Comentarios -->
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Comentarios (@Model.Comentarios.Count)</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.UserId != null)
                    {
                        if (ViewBag.TipoUsuario == "Aluno" || ViewBag.TipoUsuario == "Empresa")
                        {
                            <form asp-action="Comentar" method="post" class="mb-4">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="projetoId" value="@Model.Id" />

                                <div class="mb-2">
                                    <textarea name="texto" class="form-control" rows="3"
                                      placeholder="Escreva um comentario..." required></textarea>
                                </div>

                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send"></i> Comentar
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info mb-4">
                            <a href="/Account/Login">Faca login</a> para comentar neste projeto.
                        </div>
                    }

                    @if (Model.Comentarios != null && Model.Comentarios.Any())
                    {
                        @foreach (var comentario in Model.Comentarios.OrderByDescending(c => c.DataComentario))
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="d-flex justify-content-between">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(comentario.Aluno?.FotoPerfil))
                                        {
                                            <img src="@comentario.Aluno.FotoPerfil" class="rounded-circle me-2"
                                                 style="width: 35px; height: 35px; object-fit: cover;" />
                                        }
                                        else if (!string.IsNullOrEmpty(comentario.Empresa?.LogoEmpresa))
                                        {
                                            <img src="@comentario.Empresa.LogoEmpresa" class="rounded-circle me-2"
                                                 style="width: 35px; height: 35px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2"
                                                 style="width: 35px; height: 35px; font-size: 0.9rem;">
                                                @(comentario.Aluno?.Nome?.Substring(0, 1) ??
                                                                                    comentario.Empresa?.RazaoSocial?.Substring(0, 1)?.ToUpper())
                                </div>
                                                                }
                                       
                                        <strong>
                                            @(comentario.Aluno?.Nome ?? comentario.Empresa?.RazaoSocial)
                                        </strong>
                                    </div>
                                    <small class="text-muted">@comentario.DataComentario.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <p class="mb-0 mt-2">@comentario.Texto</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center">Nenhum comentario ainda. Seja o primeiro!</p>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar - Autor -->
        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person"></i> Autor</h5>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Aluno?.FotoPerfil))
                    {
                        <img src="@Model.Aluno.FotoPerfil" class="rounded-circle mb-3"
                             style="width: 80px; height: 80px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 80px; height: 80px; font-size: 2rem;">
                            @Model.Aluno?.Nome?.Substring(0, 1).ToUpper()
                        </div>
                    }
                    <h5>@Model.Aluno?.Nome</h5>
                    <p class="text-muted">@Model.Aluno?.Curso</p>
                    <p class="text-muted">@Model.Aluno?.Instituicao</p>

                    @if (!string.IsNullOrEmpty(Model.Aluno?.Habilidades))
                    {
                        <div class="mb-3">
                            @foreach (var hab in Model.Aluno.Habilidades.Split(',').Take(5))
                            {
                                <span class="badge bg-light text-dark">@hab.Trim()</span>
                            }
                        </div>
                    }

                    <a asp-controller="Aluno" asp-action="Perfil" asp-route-id="@Model.AlunoId"
                       class="btn btn-outline-primary w-100">
                        Ver Perfil Completo
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function curtirProjeto(projetoId) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    fetch('/Projeto/Curtir', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: 'id=' + projetoId + '&__RequestVerificationToken=' + encodeURIComponent(token)
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('totalCurtidas').textContent = data.total;
                    var btn = document.getElementById('btnCurtir');
                    var texto = document.getElementById('textoCurtir');
                    var icon = btn.querySelector('i');

                    if (data.curtiu) {
                        btn.classList.remove('btn-outline-danger');
                        btn.classList.add('btn-danger');
                        texto.textContent = 'Curtido';
                        icon.classList.remove('bi-heart');
                        icon.classList.add('bi-heart-fill');
                    } else {
                        btn.classList.remove('btn-danger');
                        btn.classList.add('btn-outline-danger');
                        texto.textContent = 'Curtir';
                        icon.classList.remove('bi-heart-fill');
                        icon.classList.add('bi-heart');
                    }
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao curtir. Tente novamente.');
            });
        }
    </script>
}