@model LinkAcademicoEmpreendedor.Models.Projeto

@{
    ViewData["Title"] = "Editar Projeto";

    var linksLista = Model.Links?.ToList()
        ?? new List<LinkAcademicoEmpreendedor.Models.ProjetoLink>();
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Editar Projeto
                    </h4>
                </div>

                <div class="card-body">
                    <form asp-action="Editar"
                          asp-route-id="@Model.Id"
                          method="post"
                          enctype="multipart/form-data">

                        <div class="mb-3">
                            <label asp-for="Titulo" class="form-label fw-bold"></label>
                            <input asp-for="Titulo" class="form-control" />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">PDF do Projeto</label>

                            @if (!string.IsNullOrEmpty(Model.ArquivoPdf))
                            {
                                <div class="mb-2">
                                    <a href="@Model.ArquivoPdf"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                        Ver PDF Atual
                                    </a>
                                </div>
                            }

                            <input type="file"
                                   name="pdfFile"
                                   class="form-control"
                                   accept=".pdf" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label fw-bold"></label>

                            <div id="editor" style="height:200px;"></div>

                            <input type="hidden" asp-for="Descricao" id="Descricao" />
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tipo do Projeto</label>
                            <select name="Tipo" class="form-select">
                                <option value="">Selecione...</option>
                                <option selected="@(Model.Tipo == "Acadêmico")">Acadêmico</option>
                                <option selected="@(Model.Tipo == "Pesquisa")">Pesquisa</option>
                                <option selected="@(Model.Tipo == "Extensão")">Extensão</option>
                                <option selected="@(Model.Tipo == "Startup")">Startup</option>
                                <option selected="@(Model.Tipo == "Outro")">Outro</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Área</label>
                            <input class="form-control bg-light" value="@Model.Area" readonly />
                        </div>

                        <div class="mt-4">
                            <h5 class="text-primary">
                                <i class="bi bi-diagram-3"></i> Informações específicas da área
                            </h5>

                            @await Html.PartialAsync("_DynamicFields",
                            (Dictionary<string, string>)ViewBag.DynamicFieldsDefinition)
                        </div>

                        <div class="mt-4">
                            <h5 class="text-success">
                                <i class="bi bi-link-45deg"></i> Links do Projeto
                            </h5>

                            <div id="links-container">

                                @if (linksLista.Any())
                                {
                                    for (int i = 0; i < linksLista.Count; i++)
                                    {
                                        <div class="row mb-2 link-row">
                                            <div class="col-md-4">
                                                <select name="Links[@i].Tipo" class="form-select">
                                                    <option selected="@(linksLista[i].Tipo == "GitHub")">GitHub</option>
                                                    <option selected="@(linksLista[i].Tipo == "Google Drive")">Google Drive</option>
                                                    <option selected="@(linksLista[i].Tipo == "Figma")">Figma</option>
                                                    <option selected="@(linksLista[i].Tipo == "YouTube")">YouTube</option>
                                                    <option selected="@(linksLista[i].Tipo == "Artigo Científico")">Artigo Científico</option>
                                                    <option selected="@(linksLista[i].Tipo == "Outro")">Outro</option>
                                                </select>
                                            </div>

                                            <div class="col-md-8">
                                                <input name="Links[@i].Url"
                                                       class="form-control"
                                                       value="@linksLista[i].Url" />
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="row mb-2 link-row">
                                        <div class="col-md-4">
                                            <select name="Links[0].Tipo" class="form-select">
                                                <option>GitHub</option>
                                                <option>Google Drive</option>
                                                <option>Figma</option>
                                                <option>YouTube</option>
                                                <option>Artigo Científico</option>
                                                <option>Outro</option>
                                            </select>
                                        </div>

                                        <div class="col-md-8">
                                            <input name="Links[0].Url" class="form-control" />
                                        </div>
                                    </div>
                                }

                            </div>

                            <button type="button"
                                    class="btn btn-outline-primary mt-2"
                                    onclick="addLink()">
                                + Adicionar Link
                            </button>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="Aluno"
                               asp-action="Dashboard"
                               class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Salvar
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

    <partial name="_ValidationScriptsPartial" />

    <script>
        const quill = new Quill('#editor', {
            theme: 'snow'
        });

        const descricaoInicial = document.getElementById("Descricao").value || "";
        quill.root.innerHTML = descricaoInicial;

        document.querySelector('form').addEventListener('submit', function () {
            document.getElementById('Descricao').value = quill.root.innerHTML;
        });
    </script>

    <script>
        let index = document.querySelectorAll('#links-container .link-row').length;

        function addLink() {
            const container = document.getElementById("links-container");

            const html = `
                <div class="row mb-2 link-row">
                    <div class="col-md-4">
                        <select name="Links[${index}].Tipo" class="form-select">
                            <option>GitHub</option>
                            <option>Google Drive</option>
                            <option>Figma</option>
                            <option>YouTube</option>
                            <option>Artigo Científico</option>
                            <option>Outro</option>
                        </select>
                    </div>

                    <div class="col-md-8">
                        <input name="Links[${index}].Url"
                               class="form-control"
                               placeholder="Cole o link aqui" />
                    </div>
                </div>`;

            container.insertAdjacentHTML("beforeend", html);
            index++;
        }
    </script>
}