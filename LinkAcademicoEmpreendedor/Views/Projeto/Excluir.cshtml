@model LinkAcademicoEmpreendedor.Models.Projeto
@{
    ViewData["Title"] = "Excluir Projeto";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-trash"></i> Excluir Projeto</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5><i class="bi bi-exclamation-triangle"></i> Atenção!</h5>
                        <p class="mb-0">Você está prestes a excluir o projeto:</p>
                    </div>

                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">@Model.Titulo</h5>
                            @if (!string.IsNullOrEmpty(Model.Tipo))
                            {
                                <span class="badge bg-primary mb-2">@Model.Tipo</span>
                            }
                            <p class="card-text text-muted">
                                @if (!string.IsNullOrEmpty(Model.Descricao))
                                {
                                    @(Model.Descricao.Length > 150 ? Model.Descricao.Substring(0, 150) + "..." : Model.Descricao)
                                }
                            </p>
                            <div class="d-flex gap-3 text-muted small">
                                <span><i class="bi bi-heart-fill text-danger"></i> @Model.Curtidas.Count curtidas</span>
                                <span><i class="bi bi-chat-fill text-primary"></i> @Model.Comentarios.Count comentarios</span>
                            </div>
                            <hr>
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> Criado em: @Model.DataCriacao.ToString("dd/MM/yyyy")
                            </small>
                        </div>
                    </div>

                    <div class="alert alert-danger">
                        <strong>Esta ação é irreversível!</strong>
                        <p class="mb-0">Ao excluir este projeto, todas as curtidas e comentários também serão removidos permanentemente.</p>
                    </div>

                    <form asp-action="ConfirmarExcluir" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Dashboard" asp-controller="Aluno" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Excluir Projeto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>