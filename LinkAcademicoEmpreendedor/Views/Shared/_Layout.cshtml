<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkillBridge</title>

    <meta name="description" content="SkillBridge — plataforma profissional que conecta talentos acadêmicos e empresas. Encontre projetos, vagas e oportunidades de colaboração." />
    <meta name="keywords" content="talentos, estágio, vagas, projetos, empresas, alunos, recrutamento" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="https://www.skillbridge.example/" />

    <meta property="og:site_name" content="SkillBridge" />
    <meta property="og:title" content="@ViewData["Title"] - SkillBridge" />
    <meta property="og:description" content="SkillBridge — plataforma profissional para conectar talentos acadêmicos e empresas. Explore projetos, vagas e colaborações." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.skillbridge.example/" />
    <meta name="theme-color" content="#0d6efd" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/skillbridge-theme.css" asp-append-version="true" />

    <style>

        .user-name-navbar {
            display: inline-block;
            max-width: 260px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            vertical-align: middle;
        }

        @@media (max-width: 1400px) {
            .user-name-navbar {
                max-width: 180px;
            }
        }

        @@media (max-width: 1200px) {
            .user-name-navbar {
                max-width: 120px;
            }
        }

        :root {
            --top-navbar-height: 72px;
            --mobile-bottom-nav-height: 68px;
            --desktop-footer-height: 60px;
            --sb-blue-900: #0a2b5e;
            --sb-blue-700: #0d47a1;
            --sb-blue-600: #1565c0;
            --sb-blue-500: #1976d2;
            --sb-blue-400: #2f8bf0;
            --sb-blue-100: #e3f0ff;
            --sb-blue-50: #f3f8ff;
            --sb-white: #ffffff;
            --sb-text: #0f1f3a;
            --sb-muted: #5b6b86;
            --sb-gradient: linear-gradient(135deg, #0d47a1 0%, #1976d2 55%, #2f8bf0 100%);
            --sb-shadow-sm: 0 4px 12px rgba(13, 71, 161, 0.08);
            --sb-shadow-md: 0 10px 30px rgba(13, 71, 161, 0.15);
            --sb-shadow-lg: 0 20px 45px rgba(13, 71, 161, 0.22);
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            height: 100%;
            margin: 0;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, sans-serif;
            color: var(--sb-text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding-top: var(--top-navbar-height);
            padding-bottom: var(--mobile-bottom-nav-height);
            background: radial-gradient(1200px 600px at 100% -10%, rgba(47,139,240,0.12), transparent 60%), radial-gradient(900px 500px at -10% 110%, rgba(13,71,161,0.08), transparent 60%), #f5f8fd;
            -webkit-font-smoothing: antialiased;
        }

        main {
            flex: 1 0 auto;
            width: 100%;
            padding-bottom: 24px;
        }

        /* ====== NAVBAR ====== */
        .navbar.sb-navbar {
            height: var(--top-navbar-height);
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: saturate(180%) blur(14px);
            -webkit-backdrop-filter: saturate(180%) blur(14px);
            border-bottom: 1px solid rgba(13, 71, 161, 0.08);
            box-shadow: var(--sb-shadow-sm);
            transition: all .25s ease;
        }

        .brand-logo {
            width: 54px;
            height: 54px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 54px;
            overflow: hidden;
            border-radius: 12px;
            background: #fff;
        }

        .brand-logo-img {
            width: 160%;
            height: 160%;
            object-fit: cover;
            object-position: center;
            display: block;
        }

        .sb-brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.05;
            min-width: 0;
        }

        .sb-brand-title {
            font-size: 1.35rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--sb-blue-600);
            white-space: nowrap;
        }

        .sb-brand-subtitle {
            font-size: 0.62rem;
            font-weight: 700;
            color: #64748b;
            white-space: nowrap;
        }

        .navbar-brand {
            text-decoration: none;
        }

        .sb-navbar .navbar-brand {
            width: 245px;
            max-width: 245px;
            display: inline-flex;
            align-items: center;
            gap: .55rem;
            flex-shrink: 0;
            background: none;
            color: inherit;
        }

            .sb-navbar .navbar-brand:hover .sb-brand-title {
                color: var(--sb-blue-700);
            }

        .sb-navbar .nav-link {
            color: var(--sb-text) !important;
            font-weight: 500;
            padding: .5rem .45rem !important;
            border-radius: 10px;
            position: relative;
            transition: all .2s ease;
            white-space: nowrap;
        }

            .sb-navbar .nav-link:hover {
                color: var(--sb-blue-600) !important;
                background: var(--sb-blue-50);
            }

        .sb-navbar .main-menu .nav-link::after {
            content: "";
            position: absolute;
            left: 50%;
            bottom: 4px;
            width: 0;
            height: 2px;
            background: var(--sb-gradient);
            border-radius: 2px;
            transition: all .25s ease;
            transform: translateX(-50%);
        }

        .sb-navbar .main-menu .nav-link:hover::after {
            width: 60%;
        }

        .sb-navbar .dropdown-menu {
            border: 1px solid rgba(13, 71, 161, 0.08);
            border-radius: 14px;
            box-shadow: var(--sb-shadow-md);
            padding: .5rem;
            margin-top: .5rem;
        }

        .sb-navbar .dropdown-item {
            border-radius: 8px;
            padding: .55rem .75rem;
            font-weight: 500;
            transition: all .15s ease;
        }

            .sb-navbar .dropdown-item:hover {
                background: var(--sb-blue-50);
                color: var(--sb-blue-700);
            }

            .sb-navbar .dropdown-item i {
                margin-right: .4rem;
                color: var(--sb-blue-600);
            }

            .sb-navbar .dropdown-item.text-danger i {
                color: #dc3545;
            }

        .navbar-toggler {
            border: 1px solid rgba(13,71,161,0.15);
            padding: .35rem .55rem;
        }

            .navbar-toggler:focus {
                box-shadow: 0 0 0 .2rem rgba(25,118,210,.2);
            }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%231565c0' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        @@media (max-width: 1200px) {
            .sb-navbar .navbar-brand {
                width: 270px;
                max-width: 270px;
            }

            .sb-brand-title {
                font-size: 1.18rem;
            }

            .sb-brand-subtitle {
                font-size: 0.66rem;
            }

            .sb-navbar .nav-link {
                padding-left: .5rem !important;
                padding-right: .5rem !important;
            }
        }

        @@media (max-width: 991.98px) {
            body {
                padding-top: var(--top-navbar-height);
            }

            .navbar.sb-navbar {
                height: auto;
                min-height: var(--top-navbar-height);
            }

            .sb-navbar .navbar-brand {
                width: auto;
                max-width: calc(100vw - 92px);
            }

            .sb-brand-subtitle {
                display: none;
            }

            .navbar-collapse {
                margin-top: .75rem;
                padding: .75rem;
                background: rgba(255,255,255,.98);
                border-radius: 14px;
                box-shadow: var(--sb-shadow-md);
            }
        }

        /* ====== ALERTS ====== */
        main .alert {
            border: none;
            border-radius: 14px;
            box-shadow: var(--sb-shadow-sm);
            font-weight: 500;
        }

        main .alert-success {
            background: #e6f7ee;
            color: #0a6b3b;
            border-left: 4px solid #1ea561;
        }

        main .alert-danger {
            background: #fdecec;
            color: #8a1a1a;
            border-left: 4px solid #dc3545;
        }

        /* ====== FOOTER ====== */
        .desktop-footer {
            flex-shrink: 0;
            width: 100%;
            background: var(--sb-gradient);
            color: #eaf2ff;
            padding: 45px 0 18px;
            margin-top: auto;
            position: relative;
            overflow: hidden;
        }

            .desktop-footer::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(600px 240px at 10% 0%, rgba(255,255,255,0.12), transparent 60%), radial-gradient(500px 240px at 90% 100%, rgba(255,255,255,0.08), transparent 60%);
                pointer-events: none;
            }

            .desktop-footer > .container {
                position: relative;
                z-index: 1;
            }

            .desktop-footer h5 {
                font-size: .95rem;
                font-weight: 700;
                letter-spacing: .04em;
                text-transform: uppercase;
                margin-bottom: 16px;
                color: #ffffff;
            }

            .desktop-footer a {
                color: #d6e4ff;
                text-decoration: none;
                transition: all .2s ease;
                font-weight: 400;
            }

                .desktop-footer a:hover {
                    color: #ffffff;
                    padding-left: 4px;
                }

            .desktop-footer ul li {
                margin-bottom: 10px;
            }

            .desktop-footer hr {
                border-color: rgba(255,255,255,0.18);
                opacity: 1;
            }

            .desktop-footer .copyright {
                font-size: .875rem;
                color: #c9d8f5;
            }

        /* ====== BOTTOM NAV MOBILE ====== */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            width: 100%;
            height: var(--mobile-bottom-nav-height);
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(12px);
            border-top: 1px solid rgba(13,71,161,0.1);
            z-index: 9999;
            box-shadow: 0 -8px 24px rgba(13,71,161,0.12);
            padding: 6px 0;
        }

            .bottom-nav .nav-link {
                color: var(--sb-muted);
                padding: 6px 0;
                font-size: .68rem;
                font-weight: 600;
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                transition: all .2s ease;
                height: 100%;
                border-radius: 12px;
                margin: 0 4px;
            }

                .bottom-nav .nav-link:hover,
                .bottom-nav .nav-link.active {
                    color: var(--sb-blue-600);
                    background: var(--sb-blue-50);
                }

                    .bottom-nav .nav-link.active i {
                        transform: scale(1.15);
                    }

                .bottom-nav .nav-link i {
                    font-size: 1.35rem;
                    margin-bottom: 2px;
                    transition: transform .2s ease;
                }

            .bottom-nav .position-relative .badge {
                position: absolute;
                top: 0;
                right: 50%;
                transform: translateX(15px);
                font-size: .55rem;
                padding: 2px 5px;
            }

        /* ====== BOTÃO IA FLUTUANTE ====== */
        .botao-ia {
            position: fixed;
            right: 22px;
            bottom: calc(var(--mobile-bottom-nav-height) + 18px);
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--sb-gradient);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.7rem;
            text-decoration: none;
            box-shadow: var(--sb-shadow-lg);
            z-index: 9998;
            transition: all .25s ease;
            animation: sbPulse 2.4s ease-in-out infinite;
        }

            .botao-ia:hover {
                transform: translateY(-3px) scale(1.05);
                color: #fff;
            }

        @@keyframes sbPulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(25,118,210,0.45), var(--sb-shadow-lg);
            }

            50% {
                box-shadow: 0 0 0 14px rgba(25,118,210,0), var(--sb-shadow-lg);
            }
        }

        @@media (min-width: 992px) {
            body {
                padding-bottom: 0;
            }

            .botao-ia {
                bottom: 90px;
            }
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg sb-navbar fixed-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-logo">
                    <img src="~/images/skillbridge-logo-sb.png"
                         asp-append-version="true"
                         alt="Logo SkillBridge"
                         class="brand-logo-img" />
                </span>

                <span class="sb-brand-text">
                    <span class="sb-brand-title">SkillBridge</span>
                    <span class="sb-brand-subtitle">Conectando talentos ao mercado</span>
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto main-menu">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Início</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Projeto" asp-action="Index">Projetos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Oportunidade" asp-action="Index">Vagas</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Aluno" asp-action="Listar">Talentos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Ajuda" asp-action="Index">Ajuda</a></li>
                </ul>

                <ul class="navbar-nav align-items-lg-center">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        var tipoUsuario = Context.Session.GetString("TipoUsuario");
                        var userName = Context.Session.GetString("UserName");
                        var userFoto = Context.Session.GetString("UserFoto");

                        <li class="nav-item d-none d-lg-block">
                            <a class="nav-link position-relative" asp-controller="Notificacao" asp-action="Index">
                                <i class="bi bi-bell fs-5"></i>
                                <span id="notificationBadgeDesktop" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                @if (!string.IsNullOrEmpty(userFoto))
                                {
                                    <img src="@userFoto" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover; border: 2px solid var(--sb-blue-100);" alt="@userName" />
                                }
                                else
                                {
                                    <i class="bi bi-person-circle me-1"></i>
                                }
                                <span class="user-name-navbar">@userName</span>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (tipoUsuario == "Aluno")
                                {
                                    <li><a class="dropdown-item" asp-controller="Aluno" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Meu painel</a></li>
                                    <li><a class="dropdown-item" asp-controller="Candidatura" asp-action="MinhasCandidaturas"><i class="bi bi-file-earmark-person"></i> Minhas candidaturas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Projeto" asp-action="Criar"><i class="bi bi-folder-plus"></i> Novo projeto</a></li>
                                    <li><a class="dropdown-item" asp-controller="Aluno" asp-action="EditarPerfil"><i class="bi bi-person-gear"></i> Editar perfil</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item" asp-controller="Empresa" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Meu painel</a></li>
                                    <li><a class="dropdown-item" asp-controller="Oportunidade" asp-action="Criar"><i class="bi bi-briefcase"></i> Nova vaga</a></li>
                                    <li><a class="dropdown-item" asp-controller="Empresa" asp-action="EditarPerfil"><i class="bi bi-building-gear"></i> Editar perfil</a></li>
                                }

                                <li><a class="dropdown-item" asp-controller="Notificacao" asp-action="Index"><i class="bi bi-bell"></i> Notificações</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="AlterarSenha"><i class="bi bi-lock"></i> Alterar senha</a></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="ExcluirConta"><i class="bi bi-trash"></i> Excluir conta</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Sair</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Entrar</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Cadastre-se
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="CadastroAluno"><i class="bi bi-mortarboard"></i> Sou aluno</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="CadastroEmpresa"><i class="bi bi-building-fill"></i> Sou empresa</a></li>
                            </ul>
                        </li>
                    }

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-trophy"></i> Rankings
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Ranking" asp-action="Alunos"><i class="bi bi-mortarboard"></i> Ranking de alunos</a></li>
                            <li><a class="dropdown-item" asp-controller="Ranking" asp-action="Empresas"><i class="bi bi-building-fill"></i> Ranking de empresas</a></li>
                        </ul>
                    </li>

                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Avaliacao" asp-action="MinhasAvaliacoes">
                                <i class="bi bi-star"></i> Avaliações
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Sucesso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }

        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Erro"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="desktop-footer">
        <div class="container">
            <div class="row w-100 text-start">
                <div class="col-md-3 mb-3">
                    <h5>SkillBridge</h5>
                    <p class="mb-0" style="color:#d6e4ff;">
                        A ponte entre talentos acadêmicos e as empresas que constroem o futuro.
                    </p>
                </div>

                <div class="col-md-3 mb-3">
                    <h5>Geral</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Account" asp-action="CadastroAluno">Cadastre-se</a></li>
                        <li><a asp-controller="Ajuda" asp-action="Index">Central de Ajuda</a></li>
                        <li><a asp-controller="Home" asp-action="Sobre">Sobre</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-3">
                    <h5>Navegação</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Oportunidade" asp-action="Index">Vagas</a></li>
                        <li><a asp-controller="Projeto" asp-action="Index">Projetos</a></li>
                        <li><a asp-controller="Aluno" asp-action="Listar">Talentos</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-3">
                    <h5>Equipe</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Desenvolvedores">Desenvolvedores</a></li>
                    </ul>
                </div>
            </div>

            <hr class="my-3">

            <div class="text-center w-100">
                <p class="mb-0 copyright">
                    SkillBridge &copy; @DateTime.Now.Year — Todos os direitos reservados.
                </p>
            </div>
        </div>
    </footer>

    <nav class="bottom-nav d-lg-none">
        <div class="container-fluid px-0">
            <div class="row g-0 text-center">
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    var tipoUsuarioNav = Context.Session.GetString("TipoUsuario");

                    <div class="col">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-fill"></i><span>Início</span>
                        </a>
                    </div>

                    <div class="col">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Oportunidade" ? "active" : "")"
                           asp-controller="Oportunidade" asp-action="Index">
                            <i class="bi bi-briefcase-fill"></i><span>Vagas</span>
                        </a>
                    </div>

                    <div class="col">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projeto" ? "active" : "")"
                           asp-controller="Projeto" asp-action="Index">
                            <i class="bi bi-folder-fill"></i><span>Projetos</span>
                        </a>
                    </div>

                    <div class="col">
                        <a class="nav-link position-relative @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notificacao" ? "active" : "")"
                           asp-controller="Notificacao" asp-action="Index">
