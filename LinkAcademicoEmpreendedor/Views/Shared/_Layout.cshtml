    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @if (Context.Session.GetInt32("UserId") != null)
    {
        <script>
            function atualizarNotificacoes() {
                fetch('/Notificacao/ContarNaoLidas')
                    .then(r => r.json())
                    .then(data => {
                        var badgeDesktop = document.getElementById('notificationBadgeDesktop');
                        var badgeMobile = document.getElementById('notificationBadgeMobile');

                        if (data.count > 0) {
                            var countText = data.count > 9 ? '9+' : data.count;

                            if (badgeDesktop) {
                                badgeDesktop.textContent = countText;
                                badgeDesktop.classList.remove('d-none');
                            }

                            if (badgeMobile) {
                                badgeMobile.textContent = countText;
                                badgeMobile.classList.remove('d-none');
                            }
                        } else {
                            if (badgeDesktop) badgeDesktop.classList.add('d-none');
                            if (badgeMobile) badgeMobile.classList.add('d-none');
                        }
                    })
                    .catch(() => console.log('Erro ao buscar Notificacoes'));
            }

            atualizarNotificacoes();
            setInterval(atualizarNotificacoes, 30000);
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <a href="/ChatBot/Index" class="botao-ia" title="Assistente IA">🤖</a>

    <div vw class="enabled">
        <div vw-access-button class="active"></div>
        <div vw-plugin-wrapper>
            <div class="vw-plugin-top-wrapper"></div>
        </div>
    </div>

    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
    <script>new window.VLibras.Widget('https://vlibras.gov.br/app');</script>
