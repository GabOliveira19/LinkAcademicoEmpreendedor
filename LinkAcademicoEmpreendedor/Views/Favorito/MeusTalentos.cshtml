@model IEnumerable<LinkAcademicoEmpreendedor.Models.FavoritoTalento>
@{
    ViewData["Title"] = "Talentos favoritos";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-star-fill text-warning"></i> Talentos favoritos</h2>
            <p class="text-muted mb-0">Alunos salvos para acompanhar e avaliar oportunidades futuras.</p>
        </div>
        <a asp-controller="Empresa" asp-action="BuscarTalentos" class="btn btn-primary">
            <i class="bi bi-search"></i> Buscar talentos
        </a>
    </div>

    <div class="row">
        @foreach (var favorito in Model)
        {
            var aluno = favorito.Aluno;
            if (aluno == null)
            {
                continue;
            }

            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        @if (!string.IsNullOrEmpty(aluno.FotoPerfil))
                        {
                            <img src="@aluno.FotoPerfil" class="rounded-circle mb-3" style="width: 72px; height: 72px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 72px; height: 72px; font-size: 1.8rem;">
                                @aluno.Nome?.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <h5>@aluno.Nome</h5>
                        <p class="text-muted mb-2">@aluno.Curso</p>
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            @if (aluno.EhEgresso)
                            {
                                <span class="badge bg-secondary">Egresso</span>
                            }
                            @if (aluno.MatriculaValidada)
                            {
                                <span class="badge bg-success">Matrícula validada</span>
                            }
                            <span class="badge bg-primary">@aluno.Projetos.Count projetos</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                        <small class="text-muted">Salvo em @favorito.CriadoEm.ToString("dd/MM/yyyy")</small>
                        <a asp-controller="Aluno" asp-action="Perfil" asp-route-id="@aluno.Id" class="btn btn-sm btn-outline-primary">
                            Ver perfil
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-people display-4 text-muted"></i>
                <p class="text-muted mt-2">Nenhum talento favoritado ainda.</p>
            </div>
        </div>
    }
</div>
