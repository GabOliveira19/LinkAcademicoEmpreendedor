@{
    ViewData["Title"] = "Redefinir Senha";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-shield-lock"></i> Nova Senha</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle"></i> @ViewBag.Erro
                        </div>
                    }

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Email: <strong>@ViewBag.Email</strong>
                    </div>

                    <form asp-action="RedefinirSenha" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="novaSenha" class="form-label">Nova Senha</label>
                            <input type="password" class="form-control" id="novaSenha" name="novaSenha"
                                   required minlength="6" placeholder="Minimo 6 caracteres">
                        </div>

                        <div class="mb-4">
                            <label for="confirmarSenha" class="form-label">Confirmar Senha</label>
                            <input type="password" class="form-control" id="confirmarSenha" name="confirmarSenha"
                                   required placeholder="Digite novamente">
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg"></i> Alterar Senha
                            </button>
                            <a asp-action="EsqueceuSenha" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Voltar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>