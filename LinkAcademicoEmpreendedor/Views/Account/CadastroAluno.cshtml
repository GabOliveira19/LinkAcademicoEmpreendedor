@model LinkAcademicoEmpreendedor.ViewModels.CadastroAlunoViewModel
@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<div class="signup-animation-page signup-aluno">
    <div class="signup-box signup-box-aluno">
        <div class="signup-content">
            <div class="signup-header">
                <div class="signup-icon">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <h2>Cadastro de Aluno</h2>
                <p>Crie seu perfil acadêmico e apresente seus projetos para empresas.</p>
            </div>
           
                    <form asp-action="CadastroAluno" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="form-check form-switch mb-3">
                            <input asp-for="EhEgresso" class="form-check-input" id="ehEgresso" />
                            <label asp-for="EhEgresso" class="form-check-label">Sou aluno egresso</label>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label">Nome Completo *</label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email *</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Senha" class="form-label">Senha *</label>
                                <input asp-for="Senha" class="form-control" />
                                <span asp-validation-for="Senha" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ConfirmarSenha" class="form-label">Confirmar Senha *</label>
                                <input asp-for="ConfirmarSenha" class="form-control" />
                                <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Curso" class="form-label">Curso</label>
                            <input asp-for="Curso" class="form-control" placeholder="Ex: Ciência da Computação" />
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Instituicao" class="form-label" id="labelInstituicao">Instituição onde estuda</label>
                                <input asp-for="Instituicao" class="form-control" placeholder="Ex: UNIFENAS" />
                            </div>

                            <div class="col-md-4 mb-3 campo-cursando">
                                <label asp-for="AnoIngresso" class="form-label">Ano de Ingresso</label>
                                <input asp-for="AnoIngresso" type="number" class="form-control" min="2000" max="@DateTime.Now.Year" />
                            </div>

                            <div class="col-md-4 mb-3 campo-egresso d-none">
                                <label asp-for="AnoConclusao" class="form-label">Ano de Conclusão</label>
                                <input asp-for="AnoConclusao" type="number" class="form-control" min="1950" max="@DateTime.Now.Year" />
                            </div>
                        </div>

                        <div class="mb-3 campo-cursando">
                            <label asp-for="Matricula" class="form-label">Matrícula do estudante</label>
                            <input asp-for="Matricula" class="form-control" placeholder="Digite sua matrícula acadêmica" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="AreaId" class="form-label">Área / Curso *</label>
                            <select asp-for="AreaId" class="form-select" asp-items="ViewBag.Areas">
                                <option value="">-- Selecione a área --</option>
                            </select>
                            <span asp-validation-for="AreaId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">
                                <i class="bi bi-share"></i> Redes sociais
                            </label>

                            <div id="redes-container">
                                <div class="row mb-2">
                                    <div class="col-md-4">
                                        <select name="Plataformas" class="form-select">
                                            <option value="Instagram">Instagram</option>
                                            <option value="LinkedIn">LinkedIn</option>
                                            <option value="Facebook">Facebook</option>
                                            <option value="E-mail">E-mail</option>
                                            <option value="WhatsApp">WhatsApp</option>
                                        </select>
                                    </div>

                                    <div class="col-md-8">
                                        <input name="Urls" class="form-control" placeholder="Cole o link ou contato aqui" />
                                    </div>
                                </div>
                            </div>

                            <button type="button" class="btn btn-outline-primary btn-sm mt-2" onclick="addRedeSocial()">
                                <i class="bi bi-plus-lg"></i> Adicionar outro link
                            </button>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-plus"></i> Cadastrar
                        </button>
                    </form>

            <div class="signup-footer">
                Já tem conta? <a asp-action="Login">Fazer login</a>
            </div>
        </div>
    </div>
</div>

<style>
    .signup-animation-page {
        min-height: calc(100vh - var(--top-navbar-height, 72px));
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem 1rem;
        background: #f3f6fb;
    }

    .signup-box {
        position: relative;
        width: min(100%, 760px);
        border-radius: 12px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 18px 45px rgba(15, 23, 42, .18);
        animation: signupEntrance .6s ease both, signupCardFloat 5s ease-in-out .7s infinite;
    }

    .signup-content {
        position: relative;
        z-index: 1;
        border-radius: 12px;
        padding: 0 2rem 2rem;
        background: #ffffff;
        color: #2b2f36;
    }

    .signup-header {
        text-align: center;
        margin: 0 -2rem 1.5rem;
        padding: 1rem 1.5rem;
        background: #0d6efd;
        border-radius: 12px 12px 0 0;
        color: #ffffff;
    }

    .signup-icon {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        margin: 0 auto 1rem;
        display: none;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #198754, #1976d2);
        color: #fff;
        font-size: 2rem;
        box-shadow: 0 0 0 4px rgba(251, 191, 36, .18), 0 12px 26px rgba(0, 0, 0, .28);
        animation: signupFloat 3s ease-in-out infinite;
    }

    .signup-header h2 {
        margin: 0;
        font-weight: 800;
        color: #fff;
        letter-spacing: 0;
    }

    .signup-header p {
        margin: .4rem auto 0;
        color: rgba(255,255,255,.85);
        max-width: 520px;
    }

    .signup-animation-page .form-label,
    .signup-animation-page .form-check-label {
        color: #2b2f36;
        font-weight: 600;
    }

    .signup-animation-page .form-control,
    .signup-animation-page .form-select {
        min-height: 46px;
        border-radius: 10px;
        border-color: #d9e0ea;
        background-color: #ffffff;
        color: #2b2f36;
    }

        .signup-animation-page .form-control::placeholder {
            color: #6c757d;
        }

        .signup-animation-page .form-control:focus,
        .signup-animation-page .form-select:focus {
            border-color: #0d6efd;
            background-color: #ffffff;
            color: #2b2f36;
            box-shadow: 0 0 0 .2rem rgba(13,110,253,.14);
        }

    .signup-animation-page .form-select option {
        color: #0f1f3a;
        background: #fff;
    }

    .signup-animation-page .btn-primary {
        min-height: 48px;
        border: none;
        border-radius: 10px;
        font-weight: 800;
        background: #0d6efd;
        box-shadow: 0 10px 22px rgba(13,110,253,.24);
    }

    .signup-animation-page .btn-outline-primary {
        border-color: #0d6efd;
        color: #0d6efd;
    }

        .signup-animation-page .btn-outline-primary:hover {
            background: #0d6efd;
            color: #ffffff;
        }

    .signup-footer {
        margin-top: 1.25rem;
        text-align: center;
        color: #2b2f36;
        border-top: 1px solid #dee2e6;
        padding-top: 1rem;
    }

        .signup-footer a {
            color: #0d6efd;
            font-weight: 800;
            text-decoration: none;
        }

            .signup-footer a:hover {
                color: #075fc3;
                text-decoration: underline;
            }

    @@keyframes signupEntrance {
        from {
            opacity: 0;
            transform: translateY(18px) scale(.96);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes signupFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-7px);
        }
    }

    @@keyframes signupCardFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-5px);
        }
    }

    @@media (max-width: 576px) {
        .signup-animation-page {
            align-items: flex-start;
            padding: 1rem;
        }

        .signup-content {
            padding: 1.25rem;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function addRedeSocial() {
            const container = document.getElementById("redes-container");

            const html = `
                <div class="row mb-2">
                    <div class="col-md-4">
                        <select name="Plataformas" class="form-select">
                            <option value="Instagram">Instagram</option>
                            <option value="LinkedIn">LinkedIn</option>
                            <option value="Facebook">Facebook</option>
                            <option value="E-mail">E-mail</option>
                            <option value="WhatsApp">WhatsApp</option>
                        </select>
                    </div>

                    <div class="col-md-8">
                        <input name="Urls" class="form-control" placeholder="Cole o link ou contato aqui" />
                    </div>
                </div>`;

            container.insertAdjacentHTML("beforeend", html);
        }

                function atualizarCamposEgresso() {
            const ehEgresso = document.getElementById("ehEgresso").checked;
            document.querySelectorAll(".campo-cursando").forEach(c => c.classList.toggle("d-none", ehEgresso));
            document.querySelectorAll(".campo-egresso").forEach(c => c.classList.toggle("d-none", !ehEgresso));
            document.getElementById("labelInstituicao").textContent = ehEgresso
                ? "Instituição onde estudou"
                : "Instituição onde estuda";
        }

        document.getElementById("ehEgresso").addEventListener("change", atualizarCamposEgresso);
        atualizarCamposEgresso();

    </script>
}
