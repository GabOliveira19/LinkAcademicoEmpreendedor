@model LinkAcademicoEmpreendedor.ViewModels.PacotesTokenViewModel
@inject Microsoft.Extensions.Options.IOptions<LinkAcademicoEmpreendedor.Settings.MercadoPagoSettings> MercadoPagoConfig
@{
    ViewData["Title"] = "Pacotes de SkillCoins";
}

<div class="container py-4">
    <div class="mb-4">
        <h3 class="mb-1"><i class="bi bi-coin"></i> Pacotes de SkillCoins</h3>
        <p class="text-muted mb-0">Escolha o pacote ideal para impulsionar suas candidaturas.</p>
    </div>

    <form id="formAntiforgery" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="row g-4">
        @foreach (var pacote in Model.Pacotes)
        {
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">@pacote.Nome</h5>
                        <div class="text-muted small mb-3">@pacote.QuantidadeTokens SkillCoins</div>
                        <div class="display-6 fw-semibold mb-4">R$ @pacote.Valor.ToString("N2")</div>
                        <button class="btn btn-primary mt-auto w-100"
                                type="button"
                                data-pacote-id="@pacote.Id"
                                data-pacote-valor="@pacote.Valor.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            Comprar
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Pacotes.Any())
    {
        <div class="alert alert-info mt-4">
            Nenhum pacote disponível no momento.
        </div>
    }
</div>

<!-- Modal do Payment Brick -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-labelledby="paymentModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="paymentModalLabel">Finalizar Pagamento</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="paymentBrick_container"></div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script src="https://sdk.mercadopago.com/js/v2"></script>
    <script>
        const tokenInput = document.querySelector('#formAntiforgery input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : '';
        const mp = new MercadoPago('@MercadoPagoConfig.Value.PublicKey', { locale: 'pt-BR' });
        const bricksBuilder = mp.bricks();
        
        let paymentBrickController = null;
        let selectedPacoteId = 0;
        const paymentModal = new bootstrap.Modal(document.getElementById('paymentModal'));

        document.querySelectorAll('[data-pacote-id]').forEach(button => {
            button.addEventListener('click', async () => {
                @if (Context.Session.GetString("TipoUsuario") != "Aluno")
                {
                    <text>
                    window.location.href = '@Url.Action("Login", "Account")';
                    return;
                    </text>
                }

                selectedPacoteId = button.getAttribute('data-pacote-id');
                const valor = parseFloat(button.getAttribute('data-pacote-valor'));
                
                await renderPaymentBrick(valor);
                paymentModal.show();
            });
        });

        const renderPaymentBrick = async (amount) => {
            if (paymentBrickController) paymentBrickController.unmount();
            
            const settings = {
                initialization: {
                    amount: amount,
                    preferenceId: null,
                },
                customization: {
                    paymentMethods: {
                        ticket: "all",
                        bankTransfer: "all",
                        creditCard: "all",
                        debitCard: "all",
                        mercadoPago: "all",
                    },
                },
                callbacks: {
                    onReady: () => {
                        // Brick renderizado
                    },
                    onSubmit: ({ selectedPaymentMethod, formData }) => {
                        return new Promise((resolve, reject) => {
                            // Adiciona pacoteId no DTO enviado ao backend
                            formData.PacoteId = selectedPacoteId;

                            fetch('@Url.Action("CriarPagamento", "Token")', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': token
                                },
                                body: JSON.stringify(formData)
                            })
                            .then(response => {
                                if(!response.ok) {
                                    response.text().then(text => { alert(text || 'Erro no pagamento'); reject(); });
                                } else {
                                    response.json().then(data => {
                                        resolve();

                                        // Salvar QrCode no localStorage para exibir na tela Pendente caso necessário
                                        if (data.qrCode) {
                                            localStorage.setItem('qrCodeBase64_' + data.id, data.qrCodeBase64);
                                            localStorage.setItem('qrCodeString_' + data.id, data.qrCode);
                                        }

                                        if (data.redirectUrl) {
                                            const separator = data.redirectUrl.includes('?') ? '&' : '?';
                                            window.location.href = data.redirectUrl + separator + "mpId=" + data.id;
                                        }
                                    });
                                }
                            })
                            .catch(error => {
                                reject();
                            });
                        });
                    },
                    onError: (error) => {
                        console.error(error);
                    },
                },
            };
            
            paymentBrickController = await bricksBuilder.create(
                "payment",
                "paymentBrick_container",
                settings
            );
        };
    </script>
}

