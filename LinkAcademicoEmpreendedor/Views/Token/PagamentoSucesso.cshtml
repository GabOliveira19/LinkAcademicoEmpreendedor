@{
    ViewData["Title"] = "Compra de SkillCoins Aprovada";
}

<div class="container py-5 text-center">
    <div class="card shadow border-success mx-auto" style="max-width: 500px;">
        <div class="card-body py-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            <h2 class="mt-4">Pagamento Aprovado!</h2>
            <p class="lead text-muted">A sua compra de SkillCoins foi confirmada com sucesso.</p>
            <p>Os SkillCoins serão creditados na sua conta em instantes, e você poderá usá-los para se candidatar às melhores oportunidades.</p>
            
            <div class="mt-4">
                <a asp-controller="Aluno" asp-action="Dashboard" class="btn btn-success btn-lg">
                    <i class="bi bi-person-badge"></i> Ir para o Dashboard
                </a>
            </div>
            
            <p class="text-muted small mt-4">ID do Pedido: @ViewBag.CompraTokenId</p>
        </div>
    </div>
</div>

