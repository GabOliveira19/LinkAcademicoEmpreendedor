@model List<LinkAcademicoEmpreendedor.Models.CompraToken>
@{
    ViewData["Title"] = "Compras de SkillCoins";
    var apenasPendentes = ViewBag.ApenasPendentes as bool? ?? false;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1"><i class="bi bi-receipt"></i> Compras de SkillCoins</h3>
            <p class="text-muted mb-0">Acompanhe suas compras e o status do pagamento.</p>
        </div>
        <a asp-controller="Aluno" asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    <div class="d-flex gap-2 mb-3">
        <a asp-action="Compras" class="btn btn-outline-primary @(apenasPendentes ? "" : "active")">
            Todas
        </a>
        <a asp-action="Compras" asp-route-status="pendente" class="btn btn-outline-warning @(apenasPendentes ? "active" : "")">
            Pendentes
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x fs-1 text-muted d-block mb-3"></i>
                    <h5>Nenhuma compra registrada</h5>
                    <p class="text-muted mb-0">Quando houver compras, elas aparecerão aqui.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Data</th>
                                <th>Pacote</th>
                                <th class="text-end">Valor</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var compra in Model)
                            {
                                var statusClass = compra.StatusPagamento switch
                                {
                                    LinkAcademicoEmpreendedor.Models.StatusPagamentoCompraToken.Aprovado => "badge bg-success",
                                    LinkAcademicoEmpreendedor.Models.StatusPagamentoCompraToken.Recusado => "badge bg-danger",
                                    LinkAcademicoEmpreendedor.Models.StatusPagamentoCompraToken.Cancelado => "badge bg-secondary",
                                    _ => "badge bg-warning text-dark"
                                };

                                <tr>
                                    <td>@compra.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@compra.PacoteToken?.Nome</td>
                                    <td class="text-end fw-semibold">R$ @compra.Valor.ToString("N2")</td>
                                    <td><span class="@statusClass">@compra.StatusPagamento</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
