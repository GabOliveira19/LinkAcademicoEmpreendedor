@model LinkAcademicoEmpreendedor.Models.Oportunidade
@{
    ViewData["Title"] = "Candidatos - " + Model.Titulo;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-people"></i> Candidatos</h2>
            <p class="text-muted mb-0">Vaga: <strong>@Model.Titulo</strong></p>
        </div>
        <a asp-controller="Oportunidade" asp-action="MinhasOportunidades" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Candidaturas == null || !Model.Candidaturas.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <h5>Nenhum candidato ainda</h5>
            <p class="mb-0">Quando alunos se candidatarem a esta vaga, aparecerão aqui.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var candidatura in Model.Candidaturas)
            {
                var statusClass = candidatura.Status == "Aceita" ? "success" :
                candidatura.Status == "Pendente" ? "warning" : "danger";
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="badge bg-@statusClass">@candidatura.Status</span>
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> @candidatura.DataCandidatura.ToString("dd/MM/yyyy")
                            </small>
                        </div>
                        <div class="card-body">
                            <div class="text-center mb-3">
                                @if (!string.IsNullOrEmpty(candidatura.Aluno?.FotoPerfil))
                                {
                                    <img src="@candidatura.Aluno.FotoPerfil" class="rounded-circle mb-2"
                                         width="80" height="80" style="object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-2"
                                         style="width: 80px; height: 80px;">
                                        <i class="bi bi-person text-white fs-2"></i>
                                    </div>
                                }
                                <h5 class="card-title mb-1">@candidatura.Aluno?.Nome</h5>
                                <p class="text-muted mb-0">@candidatura.Aluno?.Curso</p>
                            </div>

                            @if (!string.IsNullOrEmpty(candidatura.Aluno?.Email))
                            {
                                <p class="mb-1 small">
                                    <i class="bi bi-envelope text-primary"></i> @candidatura.Aluno.Email
                                </p>
                            }
                            
                        </div>
                        <div class="card-footer bg-white">
                            <div class="d-flex gap-2 flex-wrap">
                                <!-- Ver Perfil -->
                                <a asp-controller="Aluno" asp-action="Perfil" asp-route-id="@candidatura.AlunoId"
                                   class="btn btn-sm btn-outline-primary" title="Ver Perfil">
                                    <i class="bi bi-person"></i> Perfil
                                </a>

                                <!-- BOTAO AVALIAR ALUNO -->
                                <a asp-controller="Avaliacao" asp-action="AvaliarAluno"
                                   asp-route-alunoId="@candidatura.AlunoId"
                                   class="btn btn-sm btn-warning" title="Avaliar Aluno">
                                    <i class="bi bi-star"></i> Avaliar
                                </a>

                                @if (candidatura.Status == "Pendente")
                                {
                                    <a asp-action="Aceitar" asp-route-id="@candidatura.Id"
                                       class="btn btn-sm btn-success" title="Aceitar">
                                        <i class="bi bi-check-lg"></i>
                                    </a>
                                    <a asp-action="Rejeitar" asp-route-id="@candidatura.Id"
                                       class="btn btn-sm btn-danger" title="Rejeitar">
                                        <i class="bi bi-x-lg"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>