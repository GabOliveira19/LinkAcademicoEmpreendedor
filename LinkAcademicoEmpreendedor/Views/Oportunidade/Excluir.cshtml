@model LinkAcademicoEmpreendedor.Models.Oportunidade
@{
    ViewData["Title"] = "Excluir Vaga";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-trash"></i> Excluir Vaga</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5><i class="bi bi-exclamation-triangle"></i> Atencao!</h5>
                        <p class="mb-0">Voce esta prestes a excluir a vaga:</p>
                    </div>

                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">@Model.Titulo</h5>
                            <p class="card-text mb-2">
                                <span class="badge bg-primary">@Model.Tipo</span>
                                <span class="badge bg-secondary">@Model.Modalidade</span>
                                @if (Model.Ativa)
                                {
                                    <span class="badge bg-success">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Inativa</span>
                                }
                            </p>
                            <p class="card-text text-muted">
                                @if (!string.IsNullOrEmpty(Model.Descricao))
                                {
                                    @(Model.Descricao.Length > 150 ? Model.Descricao.Substring(0, 150) + "..." : Model.Descricao)
                                }
                            </p>
                            <hr>
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> Publicada em: @Model.DataPublicacao.ToString("dd/MM/yyyy")
                            </small>
                        </div>
                    </div>

                    @if (Model.Candidaturas != null && Model.Candidaturas.Any())
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-people"></i> Esta vaga possui <strong>@Model.Candidaturas.Count candidatura(s)</strong> que tambem serao removidas.
                        </div>
                    }

                    <div class="alert alert-danger">
                        <strong>Esta acao e irreversivel!</strong>
                        <p class="mb-0">Ao excluir esta vaga, todas as candidaturas recebidas tambem serao removidas permanentemente.</p>
                    </div>

                    <form asp-action="ConfirmarExcluir" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Dashboard" asp-controller="Empresa" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Excluir Vaga
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>