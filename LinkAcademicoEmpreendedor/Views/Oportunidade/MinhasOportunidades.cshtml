@model IEnumerable<LinkAcademicoEmpreendedor.Models.Oportunidade>
@{
    ViewData["Title"] = "Minhas Oportunidades";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-briefcase"></i> Minhas Oportunidades</h2>
        <div>
            <a asp-action="Criar" class="btn btn-success">
                <i class="bi bi-plus"></i> Nova Oportunidade
            </a>
            <a asp-controller="Empresa" asp-action="Dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-briefcase fs-1 d-block mb-3"></i>
            <h5>Voce ainda nao publicou nenhuma oportunidade</h5>
            <p class="mb-3">Crie sua primeira vaga para comecar a receber candidatos!</p>
            <a asp-action="Criar" class="btn btn-success">
                <i class="bi bi-plus"></i> Criar Oportunidade
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var oportunidade in Model)
            {
                var totalCandidatos = oportunidade.Candidaturas?.Count ?? 0;
                var statusClass = oportunidade.Ativa ? "success" : "secondary";

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-@statusClass text-white d-flex justify-content-between">
                            <span>@(oportunidade.Ativa ? "Ativa" : "Inativa")</span>
                            <span class="badge bg-light text-dark">
                                <i class="bi bi-people"></i> @totalCandidatos candidato(s)
                            </span>
                        </div>
                       
                            @if (oportunidade.Salario.HasValue)
                            {
                                <p class="text-success mb-2">
                                    <i class="bi bi-currency-dollar"></i> R$ @oportunidade.Salario.Value.ToString("N2")
                                </p>
                            }
                            <p class="small text-muted">
                                <i class="bi bi-calendar"></i> Publicada em @oportunidade.DataPublicacao.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="d-flex flex-wrap gap-2">
                                <a asp-action="Detalhes" asp-route-id="@oportunidade.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                                <a asp-action="Editar" asp-route-id="@oportunidade.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                @if (totalCandidatos > 0)
                                {
                                    <a asp-controller="Candidatura" asp-action="Candidatos" asp-route-oportunidadeId="@oportunidade.Id"
                                       class="btn btn-sm btn-warning">
                                        <i class="bi bi-people"></i> Ver Candidatos
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                
            }
        </div>
    }
</div>