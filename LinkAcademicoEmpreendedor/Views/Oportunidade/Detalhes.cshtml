@model LinkAcademicoEmpreendedor.Models.Oportunidade
@{
    ViewData["Title"] = Model.Titulo;
    var userId = Context.Session.GetInt32("UserId");
    var tipoUsuario = Context.Session.GetString("TipoUsuario");
    var jaCandidatou = Model.Candidaturas?.Any(c => c.AlunoId == userId) ?? false;
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <span class="badge bg-success me-2">@Model.Tipo</span>
                            <span class="badge bg-info">@Model.Modalidade</span>
                        </div>
                        <small class="text-muted">
                            Publicado em @Model.DataPublicacao.ToString("dd/MM/yyyy")
                        </small>
                    </div>

                    <h2 class="mb-3">@Model.Titulo</h2>

                    @if (Model.Salario.HasValue)
                    {
                        <p class="h4 text-success mb-4">
                            <i class="bi bi-currency-dollar"></i> R$ @Model.Salario.Value.ToString("N2")
                        </p>
                    }

                    <h5>Descricao</h5>
                    <p class="lead">@Model.Descricao</p>

                    @if (!string.IsNullOrEmpty(Model.Requisitos))
                    {
                        <h5 class="mt-4">Requisitos</h5>
                        <p>@Model.Requisitos</p>
                    }

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <p><i class="bi bi-geo-alt text-danger"></i> <strong>Local:</strong> @Model.Local</p>
                        </div>
                        <div class="col-md-6">
                            @if (Model.DataExpiracao.HasValue)
                            {
                                <p><i class="bi bi-calendar text-primary"></i> <strong>Expira em:</strong> @Model.DataExpiracao.Value.ToString("dd/MM/yyyy")</p>
                            }
                        </div>
                    </div>

                    <hr>

                    <!-- Area de Candidatura -->
                    @if (tipoUsuario == "Aluno")
                    {
                        @if (jaCandidatou)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-check-circle"></i> Voce ja se candidatou a esta vaga.
                                <a asp-controller="Candidatura" asp-action="MinhasCandidaturas" class="alert-link">
                                    Ver minhas candidaturas
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h5><i class="bi bi-send"></i> Candidatar-se a esta vaga</h5>
                                    <form asp-controller="Candidatura" asp-action="Candidatar" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="oportunidadeId" value="@Model.Id" />
                                        <div class="mb-3">
                                            <label class="form-label">Mensagem de apresentacao (opcional)</label>
                                            <textarea name="mensagem" class="form-control" rows="3"
                                              placeholder="Escreva uma mensagem para a empresa..."></textarea>
                                            <small class="text-muted">
                                                Apresente-se brevemente e diga por que voce e um bom candidato.
                                            </small>
                                        </div>
                                        <button type="submit" class="btn btn-success">
                                            <i class="bi bi-send"></i> Enviar Candidatura
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                    else if (tipoUsuario == "Empresa" && Model.EmpresaId == userId)
                    {
                        <div class="alert alert-primary">
                            <i class="bi bi-info-circle"></i> Esta e sua vaga.
                            <a asp-controller="Candidatura" asp-action="Candidatos" asp-route-oportunidadeId="@Model.Id" class="alert-link">
                                Ver @Model.TotalCandidaturas candidato(s)
                            </a>
                        </div>
                    }
                    else if (userId == null)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <a asp-controller="Account" asp-action="Login" class="alert-link">Faca login como aluno</a>
                            para se candidatar a esta vaga.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-building"></i> Empresa</h5>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Empresa?.LogoEmpresa))
                    {
                        <img src="@Model.Empresa.LogoEmpresa" class="rounded mb-3"
                             style="width: 80px; height: 80px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="bg-success text-white rounded d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 80px; height: 80px; font-size: 2rem;">
                            <i class="bi bi-building"></i>
                        </div>
                    }
                    <h5>@Model.Empresa?.RazaoSocial</h5>
                    <p class="text-muted">@Model.Empresa?.AreaAtuacao</p>

                    <a asp-controller="Empresa" asp-action="Perfil" asp-route-id="@Model.EmpresaId"
                       class="btn btn-outline-success w-100">
                        Ver Perfil da Empresa
                    </a>
                </div>
            </div>

            <!-- Estatisticas da vaga -->
            <div class="card shadow mt-3">
                <div class="card-body text-center">
                    <h4 class="text-primary">@Model.TotalCandidaturas</h4>
                    <p class="text-muted mb-0">Candidatura(s)</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Voltar para Oportunidades
        </a>
    </div>
</div>