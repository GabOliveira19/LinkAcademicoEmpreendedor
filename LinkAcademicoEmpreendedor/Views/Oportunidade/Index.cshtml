@model IEnumerable<LinkAcademicoEmpreendedor.Models.Oportunidade>
@{
    ViewData["Title"] = "Oportunidades";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-briefcase-fill text-success"></i> Oportunidades</h2>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="busca" class="form-control" placeholder="Buscar oportunidades..." value="@ViewBag.Busca" />
                </div>
                <div class="col-md-3">
                    <select name="tipo" class="form-select">
                        <option value="">Todos os tipos</option>
                        <option value="Estágio">Estágio</option>
                        <option value="CLT">CLT</option>
                        <option value="PJ">PJ</option>
                        <option value="Freelancer">Freelancer</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="modalidade" class="form-select">
                        <option value="">Todas as modalidades</option>
                        <option value="Presencial">Presencial</option>
                        <option value="Remoto">Remoto</option>
                        <option value="Híbrido">Híbrido</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Lista de Oportunidades -->
    <div class="row">
        @foreach (var oportunidade in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-success">@oportunidade.Tipo</span>
                            <span class="badge bg-info">@oportunidade.Modalidade</span>
                        </div>
                        <h5>
                            @oportunidade.Titulo

                            @{
                                var niveisPremium = ViewBag.NiveisPremiumPorEmpresa as Dictionary<int, int>;
                                var nivelPremium = niveisPremium != null && niveisPremium.ContainsKey(oportunidade.EmpresaId)
                                ? niveisPremium[oportunidade.EmpresaId]
                                : 0;
                            }

                            @if (nivelPremium > 0)
                            {
                                <span class="badge bg-warning text-dark ms-1">
                                    <i class="bi bi-gem"></i>
                                    @(nivelPremium == 3 ? "Advanced Plus" : nivelPremium == 2 ? "Advanced" : "Core")
                                </span>
                            }
                        </h5>
                        <p class="text-muted mb-2">
                            <i class="bi bi-building"></i> @oportunidade.Empresa?.RazaoSocial
                        </p>
                        <p class="text-muted mb-2">
                            <i class="bi bi-geo-alt"></i> @oportunidade.Local
                        </p>
                        @if (oportunidade.Salario.HasValue)
                        {
                            <p class="text-success fw-bold">
                                <i class="bi bi-currency-dollar"></i> R$ @oportunidade.Salario.Value.ToString("N2")
                            </p>
                        }
                        <p class="card-text small">
                            @(oportunidade.Descricao.Length > 150 ? oportunidade.Descricao.Substring(0, 150) + "..." : oportunidade.Descricao)
                        </p>
                    </div>
                    <div class="card-footer bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">@oportunidade.DataPublicacao.ToString("dd/MM/yyyy")</small>
                            <a asp-action="Detalhes" asp-route-id="@oportunidade.Id" class="btn btn-outline-success btn-sm">Ver Detalhes</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-briefcase display-1 text-muted"></i>
            <p class="lead text-muted mt-3">Nenhuma oportunidade encontrada</p>
        </div>
    }
</div>

