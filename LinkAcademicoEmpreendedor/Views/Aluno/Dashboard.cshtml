@model LinkAcademicoEmpreendedor.ViewModels.DashboardAlunoViewModel
@{
    ViewData["Title"] = "Dashboard do Aluno";
}

<div class="container py-4">
    <!-- Cabecalho do Perfil -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-auto">
                    @if (!string.IsNullOrEmpty(Model.Aluno.FotoPerfil))
                    {
                        <img src="@Model.Aluno.FotoPerfil"
                             class="rounded-circle shadow"
                             style="width: 80px; height: 80px; object-fit: cover; border: 3px solid #0d6efd;" />
                    }
                    else
                    {
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow"
                             style="width: 80px; height: 80px; font-size: 2rem;">
                            @Model.Aluno?.Nome?.Substring(0, 1).ToUpper()
                        </div>
                    }
                </div>

                <div class="col">
                    <h4 class="mb-1">@Model.Aluno?.Nome</h4>
                    <p class="text-muted mb-0">@Model.Aluno?.Curso - @Model.Aluno?.Instituicao</p>
                </div>

                <div class="col-auto">
                    <a asp-action="EditarPerfil" class="btn btn-outline-primary">
                        <i class="bi bi-pencil"></i> Editar Perfil
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Aluno.Curriculo))
    {
        <div class="card border-danger shadow-sm mb-4">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h6 class="mb-1 text-danger">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Currículo Profissional
                    </h6>
                    <small class="text-muted">
                        Seu currículo está disponível para visualização e download.
                    </small>
                </div>

                <div class="d-flex gap-2 mt-2 mt-md-0">
                    <a href="@Model.Aluno.Curriculo"
                       target="_blank"
                       class="btn btn-danger btn-lg">
                        <i class="bi bi-file-earmark-pdf"></i> Ver Currículo
                    </a>

                    <form asp-action="RemoverCurriculo" method="post"
                          onsubmit="return confirm('Deseja realmente excluir seu currículo?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            Excluir Currículo
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-secondary mb-4">
            <i class="bi bi-info-circle"></i> Nenhum currículo enviado
        </div>
    }

    <!-- Estatisticas -->
    <div class="row mb-4">
        <div class="col-md-3 col-6 mb-3">
            <div class="card bg-primary text-white shadow h-100">
                <div class="card-body text-center">
                    <h3>@Model.MeusProjetos.Count</h3>
                    <p class="mb-0">Projetos</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card bg-danger text-white shadow h-100">
                <div class="card-body text-center">
                    <h3>@Model.TotalCurtidas</h3>
                    <p class="mb-0">Curtidas</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card bg-info text-white shadow h-100">
                <div class="card-body text-center">
                    <h3>@Model.TotalComentarios</h3>
                    <p class="mb-0">Comentários</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card bg-success text-white shadow h-100">
                <div class="card-body text-center">
                    <h3>@Model.OportunidadesRecentes.Count</h3>
                    <p class="mb-0">Oportunidades</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Meus Projetos -->
    <div class="card shadow mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-folder"></i> Meus Projetos</h5>
            <a asp-controller="Projeto" asp-action="Criar" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg"></i> Novo Projeto
            </a>
        </div>
        <div class="card-body">
            @if (Model.MeusProjetos.Any())
            {
                @foreach (var projeto in Model.MeusProjetos)
                {
                    <div class="d-flex justify-content-between align-items-center border-bottom py-3">
                        <div>
                            <h6 class="mb-1">@projeto.Titulo</h6>
                            <small class="text-muted">@projeto.Tipo | @projeto.DataCriacao.ToString("dd/MM/yyyy")</small>
                            <div class="mt-1">
                                <span class="badge bg-danger"><i class="bi bi-heart-fill"></i> @projeto.TotalCurtidas</span>
                                <span class="badge bg-info"><i class="bi bi-chat-fill"></i> @projeto.TotalComentarios</span>
                            </div>
                        </div>
                        <div class="btn-group">
                            <a asp-controller="Projeto" asp-action="Detalhes" asp-route-id="@projeto.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye"></i> Ver
                            </a>
                            <a asp-controller="Projeto" asp-action="Editar" asp-route-id="@projeto.Id" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-controller="Projeto" asp-action="Excluir" asp-route-id="@projeto.Id" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Excluir
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4">
                    <p class="text-muted">Voce ainda nao tem projetos</p>
                    <a asp-controller="Projeto" asp-action="Criar" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Criar Primeiro Projeto
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Oportunidades Recentes -->
    <div class="card shadow">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-briefcase"></i> Oportunidades</h5>
        </div>
        <div class="card-body">
            @foreach (var op in Model.OportunidadesRecentes)
            {
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div>
                        <strong>@op.Titulo</strong>
                        <span class="badge bg-primary ms-2">@op.Tipo</span>
                        <br>
                        <small class="text-muted">@op.Empresa?.RazaoSocial</small>
                    </div>
                </div>
            }
        </div>
        <div class="card-footer">
            <a asp-controller="Oportunidade" asp-action="Index" class="btn btn-outline-primary btn-sm">
                Ver todas
            </a>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- SECAO DE RANKING E AVALIACOES - ADICIONAR -->
    <!-- ========================================== -->
    <div class="row mb-4">
        <!-- Card Ranking -->
        <div class="col-md-6 mb-3">
            <div class="card shadow h-100 border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-trophy"></i> Ranking</h5>
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-trophy text-warning" style="font-size: 3rem;"></i>
                    <p class="mt-3">Veja sua posição no ranking de alunos!</p>
                    <a asp-controller="Ranking" asp-action="Alunos" class="btn btn-warning">
                        <i class="bi bi-trophy"></i> Ver Ranking de Alunos
                    </a>
                    <a asp-controller="Ranking" asp-action="Empresas" class="btn btn-outline-success mt-2">
                        <i class="bi bi-building"></i> Ver Ranking de Empresas
                    </a>
                </div>
            </div>
        </div>

        <!-- Card Avaliacoes -->
        <div class="col-md-6 mb-3">
            <div class="card shadow h-100 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-star-fill"></i> Minhas Avaliações</h5>
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-star-fill text-warning" style="font-size: 3rem;"></i>
                    <p class="mt-3">Veja as avaliações que você recebeu das empresas.</p>
                    <a asp-controller="Avaliacao" asp-action="MinhasAvaliacoes" class="btn btn-primary">
                        <i class="bi bi-star"></i> Avaliações Recebidas
                    </a>
                    <a asp-controller="Avaliacao" asp-action="AvaliacoesFeitas" class="btn btn-outline-primary mt-2">
                        <i class="bi bi-send"></i> Avaliações que Fiz
                    </a>
                </div>
            </div>,

        </div>

        <!-- Card para Avaliar Empresas -->
        <div class="col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-star-fill"></i> Avaliações</h5>
                </div>
                <div class="card-body">
                    <p>Avalie as empresas que você teve contato e veja suas avaliações recebidas.</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="Avaliacao" asp-action="MinhasAvaliacoes" class="btn btn-warning">
                            <i class="bi bi-star"></i> Minhas Avaliações Recebidas
                        </a>
                        <a asp-controller="Avaliacao" asp-action="AvaliacoesFeitas" class="btn btn-outline-warning">
                            <i class="bi bi-send"></i> Avaliações que Fiz
                        </a>
                        <a asp-controller="Candidatura" asp-action="MinhasCandidaturas" class="btn btn-outline-primary">
                            <i class="bi bi-briefcase"></i> Ver Candidaturas (Avaliar Empresas)
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>